---
const steps = [
  {
    phase: "01",
    title: "Understand",
    detail: "We analyze your operations and pain points to find perfect alignment.",
    icon: "search"
  },
  {
    phase: "02",
    title: "Identify",
    detail: "We pinpoint where time is lost and where support creates impact.",
    icon: "target"
  },
  {
    phase: "03",
    title: "Build",
    detail: "We create a tailored structure with the right people for your workflow.",
    icon: "tools"
  },
  {
    phase: "04",
    title: "Integrate",
    detail: "We work as a trusted extension of your team, providing daily support.",
    icon: "users"
  }
];
---

<section class="about-process" id="process">
  <div class="container--smart">
    <div class="process-header reveal">
      <div class="header-content-wrap">
        <div class="label-box">
          <span class="label-text">The Workflow</span>
          <svg class="label-scribble" viewBox="0 0 100 20">
            <path d="M5 15 Q50 20 95 15" stroke="black" stroke-width="2" fill="none" class="scribble-path"></path>
          </svg>
        </div>
        <h2 class="section-title">
          Our 4-step integration <br/> process for growth.
          <svg class="title-scribble" viewBox="0 0 300 20">
            <path d="M10 12 Q150 18 290 12" stroke="black" stroke-opacity="0.1" stroke-width="3" fill="none" class="scribble-path"></path>
          </svg>
        </h2>
      </div>
    </div>

    <div class="process-grid">
      <!-- SVG Connecting Line (Desktop) -->
      <div class="line-container desktop-only">
        <svg class="process-line" viewBox="0 0 1000 10" preserveAspectRatio="none">
          <line x1="0" y1="5" x2="1000" y2="5" stroke="var(--color-primary)" stroke-width="2" stroke-dasharray="8,8" class="line-path" />
        </svg>
      </div>

      {steps.map((step, i) => (
        <div class="process-item" style={`--delay: ${i * 0.15}s`}>
          <div class="step-marker">
            <div class="marker-circle">
               <span class="phase-tag">Phase {step.phase}</span>
            </div>
          </div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-detail">{step.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-process {
    padding: 5rem 0;
    background-color: #fdfcf6;
    position: relative;
    overflow: hidden;
  }

  .container--smart {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .process-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-content-wrap {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 2rem;
  }

  .label-box {
    position: relative;
    padding-top: 0.5rem;
  }

  .label-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    text-transform: capitalize;
    letter-spacing: 0.05em;
  }

  .label-scribble {
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 12px;
    pointer-events: none;
  }

  .section-title {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 500;
    line-height: 1.05;
    color: #000;
    position: relative;
    letter-spacing: -3.0333px;
    margin: 0;
  }

  .title-scribble {
    position: absolute;
    bottom: -15px;
    left: 0;
    width: 100%;
    height: 20px;
    pointer-events: none;
    opacity: 0.15;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3rem;
    position: relative;
  }

  .line-container {
    position: absolute;
    top: 50px;
    left: 0;
    width: 100%;
    height: 10px;
    z-index: 1;
    display: flex;
    align-items: center;
  }

  .process-line {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .process-item {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .step-marker {
    margin-bottom: 2.5rem;
    position: relative;
  }

  .marker-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .process-item:hover .marker-circle {
    transform: translateY(-5px) scale(1.05);
    border-color: var(--color-secondary);
    background-color: var(--color-primary);
  }

  .process-item:hover .phase-tag {
    color: #fff;
  }

  .phase-tag {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: color 0.3s ease;
  }

  .step-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #000;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .step-detail {
    font-size: 0.85rem;
    line-height: 1.5;
    color: #666;
    font-weight: 500;
    max-width: 240px;
  }

  @media (max-width: 1024px) {
    .container--smart { padding: 0 1.5rem; }
    .process-grid {
      grid-template-columns: 1fr;
      gap: 5rem;
    }
    .desktop-only { display: none; }
    .marker-circle {
      width: 90px;
      height: 90px;
    }
    .process-header { margin-bottom: 5rem; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initAboutProcess = () => {
    // 1. Initial State for items
    gsap.set('.process-item', { opacity: 0, y: 30 });

    // 2. Line Animation (Scrubbed)
    const line = document.querySelector('.line-path') as SVGLineElement;
    if (line) {
      const length = 1000;
      gsap.set(line, { strokeDasharray: length, strokeDashoffset: length });

      gsap.to(line, {
        strokeDashoffset: 0,
        ease: "none",
        scrollTrigger: {
          trigger: '.process-grid',
          start: "top 60%",
          end: "bottom 80%",
          scrub: 1, // Smoothly follows the scroll
        }
      });
    }

    // 3. Sequential items reveal synchronized with scroll
    const items = gsap.utils.toArray('.process-item');
    items.forEach((item: any, i) => {
      gsap.to(item, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: item,
          start: "top 85%",
          toggleActions: "play none none reverse"
        }
      });

      // Marker specific pop
      const marker = item.querySelector('.marker-circle');
      if (marker) {
        gsap.from(marker, {
          scale: 0.5,
          opacity: 0,
          duration: 0.6,
          ease: "back.out(1.7)",
          scrollTrigger: {
            trigger: item,
            start: "top 85%",
          }
        });
      }
    });
  };

  window.addEventListener('load', initAboutProcess);
</script>
