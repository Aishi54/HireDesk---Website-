---
interface Props {
  color?: string;
}

const { color = '#5C60A6' } = Astro.props;
---

<div class="wave-divider" style={`--wave-color: ${color}`}>
  <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 120C240 40 480 0 720 0C960 0 1200 40 1440 120V0H0V120Z" fill="var(--wave-color)"></path>
  </svg>
</div>

<style>
  .wave-divider {
    width: 100%;
    height: 120px;
    margin-top: -60px; /* Overlap to blend */
    position: relative;
    z-index: 10;
  }

  svg {
    width: 100%;
    height: 100%;
    display: block;
    transform: rotate(180deg); /* Flip it so it looks like a bottom-up wave from top section */
  }

  @media (max-width: 768px) {
    .wave-divider { height: 60px; margin-top: -30px; }
  }
</style>
