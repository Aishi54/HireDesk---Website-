---
import Graphic from './Graphic.astro';

interface Props {
  title: string;
  description: string;
  bgColor?: string;
  themeColor?: string;
}

const { 
  title, 
  description, 
  bgColor = "#EBE6FF", /* Softer premium lavender */
  themeColor = "#7B61FF" /* More refined purple */
} = Astro.props;
---

<section class="service-hero">
  <div class="container--wide">
    <div class="hero-banner" style={`background-color: ${bgColor};`}>
      <div class="hero-main">
        <div class="hero-content">
          <div class="reveal">
            <div class="hero-accent">
              <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="20" cy="20" r="16" stroke="#000" stroke-width="2.5" stroke-dasharray="10 6" />
                <circle cx="24" cy="16" r="12" stroke="#888" stroke-width="1.5" stroke-dasharray="5 3" />
              </svg>
            </div>
            <h1 class="hero-title">{title}</h1>
            <p class="hero-description">{description}</p>
            <div class="cta-wrap">
               <a href="/get-started" class="btn btn-black-pill">Build your Dream Team</a>
            </div>
          </div>
        </div>

        <div class="hero-visual reveal">
          <Graphic themeColor={themeColor} size={280} />
        </div>
      </div>

      <!-- Slot for LogoCloud at bottom -->
      <div class="hero-bottom reveal">
        <slot name="bottom" />
      </div>
    </div>
  </div>
</section>

<style>
  .service-hero {
    padding: 0 0 20px; /* Minimized vertical space */
    background-color: var(--bg-primary);
    overflow: hidden;
  }

  .container--wide {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-banner {
    border-radius: 40px 40px 50% 50% / 40px 40px 80px 80px; /* Slightly tighter curve */
    padding: 60px 4rem 4rem; /* Increased vertical space significantly */
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 620px; /* Increased to maximize space */
    overflow: hidden;
  }

  .hero-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    margin-bottom: 5.5rem; /* Max breathing room */
  }

  .hero-content {
    flex: 1.1;
    max-width: 460px;
    z-index: 10;
  }

  .hero-bottom {
    width: 100%;
    margin-top: auto;
  }

  .hero-accent {
    margin-bottom: 0.75rem;
    opacity: 0.5;
  }

  .hero-title {
    font-size: clamp(1.5rem, 3.2vw, 2.2rem); /* Scaled down 'Smart' scale */
    font-weight: 500;
    line-height: 1.1;
    color: #000;
    letter-spacing: -0.04em;
    margin-bottom: 1.25rem;
  }

  .hero-description {
    font-size: 0.9rem; /* Denser, smarter profile */
    line-height: 1.5;
    color: #444;
    max-width: 440px;
    margin-bottom: 2rem;
    font-weight: 400;
  }

  .cta-wrap {
    display: flex;
    gap: 1rem;
  }

  .hero-visual {
    flex: 0.9;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  @media (max-width: 1024px) {
    .service-hero { padding-top: 10px; }
    .hero-banner {
      flex-direction: column;
      text-align: center;
      padding: 60px 2rem 0;
      border-radius: 40px;
      min-height: auto;
    }
    .hero-content {
      max-width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .cta-wrap {
      justify-content: center;
    }
    .hero-visual {
      display: none !important; /* Remove graphic on mobile per request */
    }
    .hero-title {
      font-size: 2rem;
    }
  }

  /* Reveal logic */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initServiceHero = () => {
    gsap.to('.service-hero .reveal', {
      opacity: 1,
      y: 0,
      duration: 1.2,
      stagger: 0.2,
      ease: "power3.out"
    });
  };

  window.addEventListener('load', initServiceHero);
</script>
