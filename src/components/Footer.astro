---
---

<footer class="site-footer">
  <!-- Section 1: Pre-Footer CTA with Animated Smileys -->
  <section class="pre-footer-cta-band">
    <div class="cta-arc">
      <div class="cta-inner-content reveal">
        <!-- Floating Smiley Scribbles -->
        <!-- Floating Agent Portraits (Replaces Cartoon Faces) -->
        <div class="portraits-container">
           <div class="agent-portrait p-1 reveal" role="img"><img src="/assets/sarah-sakara.png" alt="Agent" /></div>
           <div class="agent-portrait p-2 reveal" role="img"><img src="/assets/male-botm.png" alt="Agent" /></div>
           <div class="agent-portrait p-3 reveal" role="img"><img src="/assets/female-faire.png" alt="Agent" /></div>
           <div class="agent-portrait p-4 reveal" role="img"><img src="/assets/sarah-sakara.png" alt="Agent" /></div>
           <div class="agent-portrait p-5 reveal" role="img"><img src="/assets/male-botm.png" alt="Agent" /></div>
           <div class="agent-portrait p-6 reveal" role="img"><img src="/assets/female-faire.png" alt="Agent" /></div>
        </div>

        <h2 class="cta-heading">Outsourcing + <br/> built to make you better.</h2>
        <a href="#" class="btn-black pill get-started-btn">Get started</a>
      </div>
    </div>
  </section>

  <!-- Section 2: Main Branding and Links -->
  <div class="footer-main-layout">
    <div class="container--wide">
      <div class="footer-grid">
        <!-- Brand & Social Column -->
        <div class="col-brand">
          <a href="/" class="brand-logo" aria-label="Hiredesk">
            <img src="/assets/hiredesk-logo.png" alt="Hiredesk" class="logo-img-footer" />
          </a>
          <div class="social-links">
            <a href="#" class="social-circle x-icon">𝕏</a>
            <a href="#" class="social-circle f-icon">f</a>
            <a href="#" class="social-circle l-icon">in</a>
          </div>
          <div class="copyright-desktop">
             <p>© 2026 Copyright | All Rights Reserved</p>
             <p>Made with 🌶️ Hiredesk and Griflan</p>
          </div>
        </div>

        <!-- Links Multi-Column -->
        <div class="col-content">
          <!-- Newsletter Top Row -->
          <div class="newsletter-highlight">
             <h3>Sign up to our newsletter and stay hip.</h3>
             <form class="subscribe-input-wrap">
                <input type="email" placeholder="Enter Email" />
                <button type="submit">Sign Up</button>
             </form>
          </div>

          <!-- The Link Lists -->
          <div class="link-directory">
             <!-- Combined Column 1 -->
             <div class="link-col">
               <div class="link-subgroup">
                 <h4>Company</h4>
                 <ul>
                   <li><a href="/about">About</a></li>
                   <li><a href="/careers">Careers</a></li>
                   <li><a href="/contact">Contact</a></li>
                 </ul>
               </div>
             </div>
             <!-- Column 2 (Expanded Services) -->
             <div class="link-col">
               <div class="link-subgroup">
                 <h4>Our Services</h4>
                 <ul class="arrowed-links">
                    <li><a href="/services/admin-management">Admin Management</a> <span class="arr">›</span></li>
                    <li><a href="/services/customer-support">Customer Support</a> <span class="arr">›</span></li>
                    <li><a href="/services/email-support">Email Support</a> <span class="arr">›</span></li>
                 </ul>
               </div>
             </div>
          </div>
        </div>
      </div>

      <!-- Bottom Bar: Certifications & Policy -->
      <div class="footer-bottom-flex">
        <div class="certifications-bar">
          <!-- ISO Badge -->
          <div class="cert-item iso">
            <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" stroke="black" stroke-width="2" fill="none"/><text x="50" y="45" font-size="16" text-anchor="middle" font-weight="800">ISO</text><text x="50" y="65" font-size="10" text-anchor="middle">27001 Certified</text></svg>
          </div>
          <!-- MBE Badge -->
          <div class="cert-item mbe">
             <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" stroke="black" stroke-width="2" fill="none"/><text x="50" y="45" font-size="16" text-anchor="middle" font-weight="800">MBE</text><text x="50" y="65" font-size="10" text-anchor="middle">CERTIFIED</text></svg>
          </div>
          <!-- HIPAA Badge -->
          <div class="cert-item hipaa">
             <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" stroke="black" stroke-width="2" fill="none"/><text x="50" y="45" font-size="14" text-anchor="middle" font-weight="800">HIPAA</text><text x="50" y="65" font-size="10" text-anchor="middle">COMPLIANT</text></svg>
          </div>
          <!-- SOC Badge -->
          <div class="cert-item soc">
             <svg viewBox="0 0 100 100"><circle cx="50" cy="50" r="48" stroke="black" stroke-width="2" fill="none"/><text x="50" y="45" font-size="14" text-anchor="middle" font-weight="800">SOC 2</text><text x="50" y="65" font-size="10" text-anchor="middle">COMPLIANT</text></svg>
          </div>
        </div>
        <div class="footer-legal-links">
          <a href="#">Privacy Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #FFFFFF; /* High-contrast white for 'Smart Look' */
    color: #1a1a1a;
    overflow: hidden;
    border-radius: 60px 60px 0 0; /* 'Round from above' */
    margin-top: -30px; /* Slight overlap into previous section for seamless visual */
    position: relative;
    z-index: 10;
  }

  /* Pre-Footer CTA Band */
  .pre-footer-cta-band {
    padding: 8rem 0 4rem; /* Adjusted for better spacing with portraits */
    background-color: #FFFFFF;
    position: relative;
  }

  .cta-arc {
    max-width: 1400px;
    margin: 0 auto;
    background-color: #FFFFFF;
    padding: 0;
    text-align: center;
    position: relative;
  }

  .cta-inner-content { 
    position: relative; 
    z-index: 10;
    padding: 2rem 0;
  }

  .cta-heading {
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    font-weight: 500;
    line-height: 1.05;
    margin-bottom: 3rem;
    letter-spacing: -0.015em;
  }

  .get-started-btn {
    padding: 1.25rem 3.5rem;
    font-size: 1.1rem;
    font-weight: 800;
  }

  /* Portraits Container (Replaces Scribbles) */
  .portraits-container {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 1;
  }

  .agent-portrait { 
    width: 90px; height: 90px; 
    position: absolute; 
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid #4DD0E1; /* Branded cyan border */
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    background: #fff;
    transition: transform 0.4s ease;
  }
  
  .agent-portrait img { width: 100%; height: 100%; object-fit: cover; }

  /* Dynamic Positions for portraits */
  .p-1 { top: 0%; left: 12%; width: 110px; height: 110px; }
  .p-2 { top: 15%; right: 10%; width: 85px; height: 85px; }
  .p-3 { bottom: 15%; left: 6%; width: 95px; height: 95px; }
  .p-4 { bottom: 10%; right: 15%; width: 100px; height: 100px; }
  .p-5 { top: 40%; left: 2%; width: 75px; height: 75px; }
  .p-6 { top: 35%; right: 4%; width: 80px; height: 80px; }

  @media (max-width: 768px) {
    .agent-portrait { width: 60px; height: 60px; }
    .p-1 { top: -5%; left: 5%; }
    .p-2 { top: 10%; right: 5%; }
    .p-3 { display: none; }
    .p-4 { bottom: 0%; right: 10%; }
    .p-5 { display: none; }
    .p-6 { top: 40%; right: -5%; }
  }

  /* Main Footer Layout */
  .footer-main-layout {
    padding-bottom: 2rem; /* Reduced from 6rem */
    background: #FFFFFF;
  }

  .container--wide {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 8%;
    margin-bottom: 2rem; /* Significantly reduced from 6rem */
  }

  @media (max-width: 1024px) {
    .footer-grid { 
      grid-template-columns: 1fr; 
      gap: 3rem; 
      margin-bottom: 2rem; 
      text-align: center; /* FULL CENTER */
    }
    .container--wide { padding: 0 1.5rem; }
    .col-brand {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .social-links {
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .subscribe-input-wrap {
      margin: 0 auto;
    }
    .link-directory {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }
    .link-subgroup li {
      justify-content: center;
    }
    .footer-bottom-flex {
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-top: 1.5rem;
    }
    .certifications-bar {
      justify-content: center;
    }
    .copyright-desktop {
      margin-top: 2rem;
    }
  }

  /* Right Col content */
  .col-content { display: flex; flex-direction: column; gap: 3rem; } /* Reduced from 5rem */

  .brand-logo {
    display: block;
    margin-bottom: 2rem;
  }

  .logo-img-footer {
     display: block;
     height: 140px; /* Bolder brand anchor prominence */
     width: auto;
  }

  .social-links {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 3.5rem; /* Reduced from 5rem */
  }

  .social-circle {
    width: 48px; height: 48px;
    border-radius: 50%;
    background-color: #4DD0E1; /* Branded Cyan */
    display: flex; align-items: center; justify-content: center;
    color: #000; font-weight: 900; text-decoration: none; font-size: 1.15rem;
    transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .social-circle:hover { transform: translateY(-3px) scale(1.05) rotate(6deg); }

  .copyright-desktop { font-size: 0.85rem; color: #666; line-height: 1.7; font-weight: 500; }

  /* Newsletter Box */
  .newsletter-highlight h3 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1.5rem; /* Reduced from 2rem */
    letter-spacing: -0.02em;
  }

  .subscribe-input-wrap {
    display: flex;
    max-width: 500px;
    background: #F9F9F7; /* Subtle off-white for input wrap */
    border: 1.5px solid #F1F1ED;
    border-radius: 100px;
    padding: 6px;
  }

  .subscribe-input-wrap input {
    flex: 1; border: none; outline: none; padding: 0 1.5rem; font-size: 1rem; background: transparent;
    font-family: inherit;
  }

  .subscribe-input-wrap button {
    background: #000000; /* Black for 'Smart' look */
    border: none; border-radius: 100px; padding: 0.85rem 2.5rem;
    color: #fff; font-weight: 700; cursor: pointer; transition: all 0.3s ease;
  }
  .subscribe-input-wrap button:hover { opacity: 0.9; transform: translateX(2px); }

  /* Directory Grid */
  .link-directory {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Reduced to 2 columns for a cleaner look */
    gap: 4rem;
  }

  @media (max-width: 768px) { .link-directory { grid-template-columns: repeat(2, 1fr); gap: 2rem; } }

  .link-subgroup { margin-bottom: 1.5rem; } /* Significantly reduced from 3rem */
  .link-subgroup h4 { font-size: 1.05rem; font-weight: 800; margin-bottom: 1.25rem; color: #000; }
  .standalone-h { line-height: 1.2; }

  .link-subgroup ul { list-style: none; padding: 0; margin: 0; }
  .link-subgroup li { margin-bottom: 0.85rem; display: flex; align-items: center; gap: 0.4rem; }
  .link-subgroup a { text-decoration: none; color: #555; font-weight: 500; font-size: 1rem; transition: color 0.2s; }
  .link-subgroup a:hover { color: #000; text-decoration: none; }

  .arrowed-links a { font-weight: 600; color: #000; }
  .arr { font-size: 1.2rem; font-weight: 700; color: #000; opacity: 0.3; transition: opacity 0.2s; }
  .arrowed-links li:hover .arr { opacity: 1; }

  address { font-style: normal; color: #666; line-height: 1.6; font-size: 1rem; font-weight: 500; }

  /* Bottom Bar */
  .footer-bottom-flex {
    border-top: 1px solid rgba(0,0,0,0.06);
    padding: 1rem 0 2rem; /* Significantly reduced to minimize bottom gap */
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .certifications-bar { display: flex; gap: 1.5rem; align-items: center; }
  .cert-item { width: 65px; height: 65px; opacity: 0.45; transition: opacity 0.3s ease; }
  .cert-item:hover { opacity: 1; }

  .footer-legal-links a { text-decoration: none; color: #777; font-weight: 600; font-size: 0.9rem; transition: color 0.2s; }
  .footer-legal-links a:hover { color: #000; }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initBetterFooter = () => {
    gsap.to('.pre-footer-cta-band .reveal', {
      opacity: 1, y: 0, duration: 1.2,
      scrollTrigger: { trigger: '.pre-footer-cta-band', start: 'top 80%' }
    });

    const items = document.querySelectorAll('.agent-portrait');
    items.forEach((box, i) => {
      gsap.to(box, {
        y: -15, x: i % 2 === 0 ? 8 : -8,
        duration: 3 + i * 0.4,
        repeat: -1, yoyo: true,
        ease: 'sine.inOut'
      });
    });
  };

  window.addEventListener('load', initBetterFooter);
</script>
