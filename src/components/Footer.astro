            >
          </div>
          <!-- MBE Badge -->
          <div class="cert-item mbe">
            <svg viewBox="0 0 100 100"
              ><circle
                cx="50"
                cy="50"
                r="48"
                stroke="black"
                stroke-width="2"
                fill="none"></circle><text
                x="50"
                y="45"
