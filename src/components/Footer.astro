</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initBetterFooter = () => {
    gsap.to(".pre-footer-cta-band .reveal", {
      opacity: 1,
      y: 0,
      duration: 1.2,
      scrollTrigger: { trigger: ".pre-footer-cta-band", start: "top 80%" },
    });

    const items = document.querySelectorAll(".agent-portrait");
    items.forEach((box, i) => {
      gsap.to(box, {
        y: -15,
        x: i % 2 === 0 ? 8 : -8,
        duration: 3 + i * 0.4,
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
      });
    });
    // Newsletter Submission Logic
    const newsletterForm = document.getElementById('newsletterForm');
    newsletterForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('newsletterEmail') as HTMLInputElement;
      const submitBtn = document.getElementById('newsletterSubmit');
      
      if (emailInput.value) {
        if (submitBtn) {
          submitBtn.innerText = "Sending...";
          submitBtn.style.opacity = "0.7";
        }

        const payload = {
          "_subject": "🔔 New Newsletter Subscription | HireDesk",
          "--- Subscription Update ---": "",
          "Status": "A new visitor has subscribed to your newsletter.",
          "Subscriber Email": emailInput.value,
          "Submitted On": new Date().toLocaleString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true }) + " (UTC)",
          "Summary": `${emailInput.value} has requested to receive HireDesk tech updates and news.`
        };

        try {
          const response = await fetch("https://formsubmit.co/ajax/nazarayesha547@gmail.com", {
            method: "POST",
            body: JSON.stringify(payload),
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json'
            }
          });

          if (response.ok) {
            if (submitBtn) {
              submitBtn.innerText = "Subscribed!";
              submitBtn.style.backgroundColor = "#54c6d7"; // Viking Blue
              submitBtn.style.opacity = "1";
            }
            emailInput.value = "";
            setTimeout(() => {
              if (submitBtn) {
                submitBtn.innerText = "Sign Up";
                submitBtn.style.backgroundColor = ""; 
              }
            }, 3000);
          }
        } catch (error) {
          if (submitBtn) submitBtn.innerText = "Sign Up";
        }
      }
    });
  };

  window.addEventListener("load", initBetterFooter);
</script>
