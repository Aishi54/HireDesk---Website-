<footer class="site-footer">
  <!-- Section 1: Pre-Footer CTA with Animated Smileys -->
  <section class="pre-footer-cta-band">
    <div class="cta-arc">
      <div class="cta-inner-content reveal">
        <!-- Floating Smiley Scribbles -->
        <!-- Floating Agent Portraits (Replaces Cartoon Faces) -->
        <div class="portraits-container">
          <div class="agent-portrait p-1 reveal" role="img">
            <img src="/assets/lead-funmi.png" alt="Agent" />
          </div>
          <div class="agent-portrait p-2 reveal" role="img">
            <img src="/assets/male-botm.png" alt="Agent" />
          </div>
          <div class="agent-portrait p-3 reveal" role="img">
            <img src="/assets/lead-taire.png" alt="Agent" />
          </div>
          <div class="agent-portrait p-4 reveal" role="img">
            <img src="/assets/sarah-sakara.png" alt="Agent" />
          </div>
          <div class="agent-portrait p-5 reveal" role="img">
            <img src="/assets/lead-travis.png" alt="Agent" />
          </div>
          <div class="agent-portrait p-6 reveal" role="img">
            <img src="/assets/female-faire.png" alt="Agent" />
          </div>
        </div>

        <h2 class="cta-heading">
          Ready to Create More <br /> Space for Growth?
        </h2>
        <p class="cta-description reveal">
          If your business is spending too much time managing day-to-day operations and not enough time moving forward, Hire Desk can help.
        </p>
        <a href="/contact" class="btn-black pill get-started-btn">Let's talk</a>
      </div>
    </div>
  </section>

  <!-- Section 2: Main Branding and Links -->
  <div class="footer-main-layout">
    <div class="container--wide">
      <div class="footer-grid">
        <!-- Brand & Social Column -->
        <div class="col-brand">
          <a href="/" class="brand-logo" aria-label="Hiredesk">
            <img
              src="/assets/hiredesk-logo.png"
              alt="Hiredesk"
              class="logo-img-footer"
            />
          </a>
          <div class="social-links">
            <a href="#" class="social-circle x-icon">𝕏</a>
            <a href="#" class="social-circle f-icon">f</a>
            <a href="#" class="social-circle l-icon">in</a>
          </div>
          <div class="copyright-desktop">
            <p>© 2026 Copyright | All Rights Reserved</p>
          </div>
        </div>

        <!-- Links Multi-Column -->
        <div class="col-content">
          <!-- Newsletter Top Row -->
          <div class="newsletter-highlight">
            <h3>Sign up to our newsletter and stay hip.</h3>
            <form class="subscribe-input-wrap" id="newsletterForm">
              <input type="email" id="newsletterEmail" placeholder="Enter Email" required />
              <button type="submit" id="newsletterSubmit">Sign Up</button>
            </form>
          </div>

          <!-- The Link Lists -->
          <div class="link-directory">
            <!-- Combined Column 1 -->
            <div class="link-col">
              <div class="link-subgroup">
                <h4>Company</h4>
                <ul>
                  <li><a href="/about">About</a></li>
                  <li><a href="/careers">Careers</a></li>
                  <li><a href="/contact">Contact</a></li>
                </ul>
              </div>
            </div>
            <!-- Column 2 (Expanded Services) -->
            <div class="link-col">
              <div class="link-subgroup">
                <h4>Our Services</h4>
                <ul class="arrowed-links">
                  <li>
                    <a href="/services/financial-support">Financial Support</a>
                    <span class="arr">›</span>
                  </li>
                  <li>
                    <a href="/services/back-office-support">Back Office Support</a>
                    <span class="arr">›</span>
                  </li>
                  <li>
                    <a href="/services/executive-support">Executive Support</a>
                    <span class="arr">›</span>
                  </li>
                  <li>
                    <a href="/services/additional-support">Additional Support</a>
                    <span class="arr">›</span>
                  </li>
                </ul>
              </div>
            </div>
            <!-- Column 3 (Case Studies) -->
            <div class="link-col">
              <div class="link-subgroup">
                <h4>Case Studies</h4>
                <ul class="arrowed-links">
                  <li>
                    <a href="/case-studies/founder-bottleneck">Founder Story</a>
                    <span class="arr">›</span>
                  </li>
                  <li>
                    <a href="/case-studies/scaling-systems">SME Scaling</a>
                    <span class="arr">›</span>
                  </li>
                  <li>
                    <a href="/case-studies/hiring-alternative">Hiring Strategy</a>
                    <span class="arr">›</span>
                  </li>
                </ul>
              </div>
