---
const services = [
  {
    title: 'Financial Support',
    description: 'Handling the numbers that slow you down, so you can focus on scaling your business.',
    color: '#54c6d7', // Viking Blue
    link: '/services/financial-support',
    icon: `<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="20" y="30" width="60" height="40" rx="4" stroke="#54c6d7" stroke-width="6"/>
      <path d="M40 50 L 60 50 M 50 40 L 50 60" stroke="#54c6d7" stroke-width="6" stroke-linecap="round"/>
    </svg>`
  },
  {
    title: 'Back Office Support',
    description: 'Streamlining your operations to take the friction out of daily administration.',
    color: '#6484c2', // Danube
    link: '/services/back-office-support',
    icon: `<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 20 H 80 V 80 H 20 Z" stroke="#6484c2" stroke-width="6"/>
      <path d="M35 40 H 65 M 35 55 H 65 M 35 70 H 50" stroke="#6484c2" stroke-width="6" stroke-linecap="round"/>
    </svg>`
  },
  {
    title: 'Executive Support',
    description: 'A trusted extension of your leadership, managing the details for businesses who move fast.',
    color: '#5b62ad', // Scampi
    link: '/services/executive-support',
    icon: `<svg viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="60" cy="35" r="15" stroke="#5b62ad" stroke-width="6"/>
      <path d="M30 80 Q 60 50 90 80" stroke="#5b62ad" stroke-width="6" stroke-linecap="round"/>
    </svg>`
  },
  {
    title: 'Additional Support',
    description: 'High-performing support that scales with you, giving you more space for growth.',
    color: '#54c6d7', // Viking
    link: '/services/additional-support',
    icon: `<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="50" cy="50" r="30" stroke="#54c6d7" stroke-width="6" stroke-dasharray="10 5"/>
      <path d="M50 35 V 65 M 35 50 H 65" stroke="#54c6d7" stroke-width="6" stroke-linecap="round"/>
    </svg>`
  }
];
---

<section class="services-wrapper">
  <div class="container--wide">
    <div class="services-header reveal">
      <div class="header-content-wrap">
        <div class="label-box">
          <span class="label-text">Our Services</span>
          <svg class="label-scribble" viewBox="0 0 100 20">
            <path d="M5 15 Q50 20 95 15" stroke="black" stroke-width="2" fill="none" class="scribble-path"></path>
          </svg>
        </div>
        <h2 class="section-title">
          WHAT WE DO
          <svg class="title-scribble" viewBox="0 0 300 20">
            <path d="M10 12 Q150 18 290 12" stroke="black" stroke-opacity="0.1" stroke-width="3" fill="none" class="scribble-path"></path>
          </svg>
        </h2>
      </div>
      <p class="section-desc">We provide support across a range of business functions, tailored to help you operate more effectively.</p>
    </div>

    <div class="grid-container">
      <!-- Arcs (Desktop Only) -->
      <div class="arcs-overlay">
        <div class="arc-spacer"></div>
        <svg class="arc-svg" viewBox="0 0 100 40">
          <path d="M0 40 Q50 0 100 40" stroke="black" stroke-width="2.5" stroke-dasharray="6 6" fill="none"/>
        </svg>
        <div class="arc-spacer double"></div>
        <svg class="arc-svg" viewBox="0 0 100 40">
          <path d="M0 40 Q50 0 100 40" stroke="black" stroke-width="2.5" stroke-dasharray="6 6" fill="none"/>
        </svg>
        <div class="arc-spacer"></div>
      </div>

      <div class="slider-viewport">
        <div class="services-grid" id="servicesGrid">
          {services.map((service) => (
            <div class="service-card reveal" style={`--accent: ${service.color}`}>
              <div class="card-inner">
                <div class="card-icon-wrapper">
                  <div class="card-icon" set:html={service.icon}></div>
                  <svg class="orbital-ring" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="45" stroke="var(--accent)" stroke-width="3" stroke-dasharray="20 150" fill="none" class="orbit-path" />
                  </svg>
                </div>
                <h3 class="card-title">{service.title}</h3>
                <p class="card-text">{service.description}</p>
                <div class="card-footer">
                  <a href={service.link} class="btn-learn">Learn More</a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Mobile Navigation Controls (Pinned to End of Cards) -->
      <div class="mobile-only">
        <div class="mobile-nav-controls">
          <button class="nav-arrow prev-btn" aria-label="Previous">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
          
          <div class="pagination-dots">
            {services.map((_, i) => (
              <div class={`dot ${i === 0 ? 'active' : ''}`} data-index={i}></div>
            ))}
          </div>

          <button class="nav-arrow next-btn" aria-label="Next">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .services-wrapper {
    background: var(--bg-primary);
    padding: 4.5rem 0 3.5rem;
    position: relative;
    overflow: hidden;
  }

  .container--wide {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .services-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-content-wrap {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 2rem;
  }

  .label-box {
    position: relative;
    padding-top: 0.5rem;
  }

  .label-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    text-transform: capitalize;
    letter-spacing: 0.05em;
  }

  .label-scribble {
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 12px;
    pointer-events: none;
  }

  .section-title {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 500;
    line-height: 1.05;
    color: #000;
    position: relative;
    letter-spacing: -3.0333px;
    margin: 0;
  }

  .title-scribble {
    position: absolute;
    bottom: -15px;
    left: 0;
    width: 100%;
    height: 20px;
    pointer-events: none;
    opacity: 0.15;
  }

  .section-desc {
    font-size: 1rem;
    color: #555;
    max-width: 580px;
    line-height: 1.5;
    font-weight: 400;
    margin: 0 auto;
  }

  /* Global Visibility Utilities */
  .mobile-only {
    display: none !important;
  }

  @media (max-width: 1024px) {
    .mobile-only {
      display: block !important;
    }
  }

  .grid-container {
    position: relative;
    width: 100%;
    overflow: visible;
  }

  /* Precise Arcs (Desktop Only) */
  .arcs-overlay {
    position: absolute;
    top: -45px;
    left: 0;
    right: 0;
    display: grid;
    grid-template-columns: 1fr 100px 1fr 100px 1fr;
    align-items: end;
    pointer-events: none;
    z-index: 10;
  }

  .arc-svg {
    width: 100px;
    height: 40px;
    margin-bottom: -10px;
  }

  @media (max-width: 1024px) {
    .arcs-overlay { display: none; }
  }

  /* Slider Viewport & Mobile Snap */
  .slider-viewport {
    width: 100%;
    position: relative;
    overflow: visible;
  }

  /* Grid Layout (Desktop) */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
    z-index: 2;
  }

  .mobile-nav-controls {
    display: none;
  }

  .nav-arrow {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #54c6d7; /* Viking blue circle per request */
    color: #000;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    pointer-events: auto;
  }

  .nav-arrow:active { transform: scale(0.9); }

  /* Pagination Dots */
  .pagination-dots {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid #000;
    transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
  }
  
  .dot.active {
    background: #000;
    transform: scale(1.2);
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .container--wide { padding: 0; }
    .services-header { padding: 0 1.5rem; }

    .slider-viewport {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
      padding: 1rem 1.5rem 3rem; /* Allows card peeking */
    }
    .slider-viewport::-webkit-scrollbar { display: none; }

    .services-grid {
      display: flex;
      gap: 1.25rem;
      grid-template-columns: none;
      width: max-content;
    }

    .service-card {
      flex: 0 0 calc(100vw - 4rem); /* Responsive width with peeking */
      max-width: 320px;
      scroll-snap-align: center;
    }

    .mobile-nav-controls {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
      margin: 2.5rem 0 0; /* Clear spacing at the 'end' of cards */
      pointer-events: auto;
      width: 100%;
    }
  }

  /* Compact Smart Card */
  .service-card {
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    text-align: center;
    border: 1px solid rgba(0,0,0,0.06);
    outline: 2px solid var(--accent);
    outline-offset: -2px;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: 0 15px 35px rgba(0,0,0,0.03);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.05);
    outline-width: 3px;
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-icon-wrapper {
    position: relative;
    width: 90px;
    height: 90px;
    margin: 0 auto 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .orbital-ring {
    position: absolute;
    top: -15px;
    left: -15px;
    width: 120px;
    height: 120px;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  .card-title {
    font-size: 1.15rem; /* Slightly larger heading */
    font-weight: 700;
    margin-bottom: 0.85rem;
    color: #000;
  }

  .card-text {
    font-size: 0.95rem; /* Slightly larger text for readability */
    color: #555;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    flex-grow: 1; /* Pushes button to bottom */
  }

  .card-footer {
    margin-top: auto;
  }

  .btn-learn {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 0.65rem 1.5rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-learn:hover {
    background: #222;
    transform: scale(1.03);
  }

  /* Reveal logic */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initServicesAnimations = () => {
    gsap.to('.service-card.reveal', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: '.services-wrapper',
        start: "top 80%"
      }
    });

    // Suble floating animation
    gsap.to('.card-icon-wrapper', {
       y: -10,
       duration: 2.5,
       repeat: -1,
       yoyo: true,
       stagger: 0.2,
       ease: "sine.inOut"
    });

    // Orbital rotation
    gsap.to('.orbit-path', {
      strokeDashoffset: -170,
      duration: 3,
      repeat: -1,
      ease: "none",
      stagger: 0.2
    });
  };

  const initServicesSlider = () => {
    const viewport = document.querySelector('.slider-viewport');
    const grid = document.getElementById('servicesGrid');
    const prevBtn = document.querySelector('.prev-btn');
    const nextBtn = document.querySelector('.next-btn');
    const dots = document.querySelectorAll('.pagination-dots .dot');
    const cards = document.querySelectorAll('.service-card');
    
    if (!viewport || !grid || !prevBtn || !nextBtn || cards.length === 0) return;

    let currentIndex = 0;

    const syncSlider = () => {
       const scrollLeft = viewport.scrollLeft;
       const cardWidth = cards[0].clientWidth + 20; // width + gap
       const index = Math.round(scrollLeft / cardWidth);
       
       if (index !== currentIndex) {
          currentIndex = index;
          dots.forEach((dot, i) => {
             if (i === currentIndex) dot.classList.add('active');
             else dot.classList.remove('active');
          });
       }
    };

    viewport.addEventListener('scroll', syncSlider);

    prevBtn.addEventListener('click', () => {
       viewport.scrollBy({ left: -(cards[0].clientWidth + 20), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
       viewport.scrollBy({ left: (cards[0].clientWidth + 20), behavior: 'smooth' });
    });

    syncSlider(); // Init state
  };

  window.addEventListener('load', () => {
    initServicesAnimations();
    initServicesSlider();
  });
</script>
