---
const services = [
  {
    title: 'Customer Support',
    description: 'Across time zones, languages, cultures, and channels, we’ll leave your customers feeling great about your brand…even if it’s a bad day.',
    color: '#1AC4D3',
    icon: `<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M40 70 C 45 60 55 60 60 70" stroke="#1AC4D3" stroke-width="6" stroke-linecap="round"/>
      <path d="M30 75 C 40 50 60 50 70 75" stroke="#1AC4D3" stroke-width="6" stroke-linecap="round" opacity="0.6"/>
      <path d="M20 80 C 35 35 65 35 80 80" stroke="#1AC4D3" stroke-width="6" stroke-linecap="round" opacity="0.3"/>
    </svg>`
  },
  {
    title: 'Data & AI',
    description: 'Process and build with better, less biased, more accurate training data. You know your end product depends on it; we do too.',
    color: '#FF5C39',
    icon: `<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="30" y="30" width="40" height="40" rx="10" stroke="#FF5C39" stroke-width="10"/>
      <rect x="42" y="42" width="16" height="16" rx="4" fill="#FF5C39" opacity="0.3"/>
    </svg>`
  },
  {
    title: 'Trust & Safety',
    description: 'Better compliance, higher engagement, and safer spaces. We’ll keep your users playing by your rules.',
    color: '#9B51E0',
    icon: `<svg viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="45" cy="50" r="22" stroke="#9B51E0" stroke-width="8"/>
      <circle cx="75" cy="50" r="22" stroke="#9B51E0" stroke-width="8" opacity="0.5"/>
    </svg>`
  },
  {
    title: 'Digital Operations',
    description: 'Crash costs cut friction, and boost efficiency. We’ll help you scale your operations faster and more profitably… and put years back on your life.',
    color: '#6FCF97',
    icon: `<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="38" cy="38" r="12" stroke="#6FCF97" stroke-width="6"/>
      <circle cx="62" cy="38" r="12" stroke="#6FCF97" stroke-width="6"/>
      <circle cx="38" cy="62" r="12" stroke="#6FCF97" stroke-width="6"/>
      <circle cx="62" cy="62" r="12" stroke="#6FCF97" stroke-width="6"/>
    </svg>`
  }
];
---

<section class="services-wrapper">
  <div class="container--wide">
    <div class="services-header">
      <h2 class="reveal">+ More Growth, Less Risk</h2>
      <p class="reveal">Focus on growth, we’ll take care of the many small tasks that make the difference between awesome and awful.</p>
    </div>

    <div class="grid-container">
      <!-- Arcs positioned precisely over the gaps -->
      <div class="arcs-overlay">
        <div class="arc-spacer"></div>
        <svg class="arc-svg" viewBox="0 0 100 40">
          <path d="M0 40 Q50 0 100 40" stroke="black" stroke-width="2.5" stroke-dasharray="6 6" fill="none"/>
        </svg>
        <div class="arc-spacer double"></div>
        <svg class="arc-svg" viewBox="0 0 100 40">
          <path d="M0 40 Q50 0 100 40" stroke="black" stroke-width="2.5" stroke-dasharray="6 6" fill="none"/>
        </svg>
        <div class="arc-spacer"></div>
      </div>

      <div class="services-grid">
        {services.map((service) => (
          <div class="service-card reveal" style={`--accent: ${service.color}`}>
            <div class="card-inner">
              <div class="card-icon-wrapper">
                <div class="card-icon" set:html={service.icon}></div>
                <!-- Orbital Ring -->
                <svg class="orbital-ring" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="45" stroke="var(--accent)" stroke-width="2" stroke-dasharray="20 150" fill="none" class="orbit-path" />
                </svg>
              </div>
              <h3 class="card-title">{service.title}</h3>
              <p class="card-text">{service.description}</p>
              <div class="card-footer">
                <a href="#" class="btn-learn">Learn More</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .services-wrapper {
    background: var(--bg-primary);
    padding: 1.5rem 0 1rem;
    position: relative;
    overflow: hidden;
  }

  .container--wide {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .services-header {
    text-align: center;
    margin-bottom: 4rem; /* Reduced space */
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h2 {
    font-size: clamp(1.6rem, 3.2vw, 2.2rem); /* Matching page scale */
    font-weight: 500;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    color: #000;
  }

  .services-header p {
    font-size: 0.95rem; /* Denser, smarter profile */
    color: #444;
    max-width: 600px;
    line-height: 1.5;
    font-weight: 400;
  }

  .grid-container {
    position: relative;
    width: 100%;
  }

  /* Precise Arcs */
  .arcs-overlay {
    position: absolute;
    top: -45px; /* Sits above the grid */
    left: 0;
    right: 0;
    display: grid;
    grid-template-columns: 1fr 100px 1fr 100px 1fr; /* Spacers and arcs */
    align-items: end;
    pointer-events: none;
    z-index: 10;
  }

  .arc-svg {
    width: 100px;
    height: 40px;
    margin-bottom: -10px;
  }

  @media (max-width: 1024px) {
    .arcs-overlay { display: none; }
  }

  /* Grid Layout */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
  }

  /* Compact Smart Card */
  .service-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem 1.25rem; /* Drastically reduced to make them smart */
    text-align: center;
    border: 1px solid rgba(0,0,0,0.06);
    outline: 2px solid var(--accent);
    outline-offset: -2px;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.05);
    outline-width: 3px;
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-icon-wrapper {
    position: relative;
    width: 60px;
    height: 60px;
    margin: 0 auto 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .orbital-ring {
    position: absolute;
    top: -10px;
    left: -10px;
    width: 80px;
    height: 80px;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  .card-title {
    font-size: 1rem; /* Scaled down */
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: #000;
  }

  .card-text {
    font-size: 0.85rem; /* Denser, smarter profile */
    color: #555;
    line-height: 1.4;
    margin-bottom: 1.25rem;
    flex-grow: 1; /* Pushes button to bottom */
  }

  .card-footer {
    margin-top: auto;
  }

  .btn-learn {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 0.65rem 1.5rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-learn:hover {
    background: #222;
    transform: scale(1.03);
  }

  /* Reveal logic */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initServicesAnimations = () => {
    gsap.to('.reveal', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: '.services-wrapper',
        start: "top 80%"
      }
    });

    // Suble floating animation for icons
    gsap.to('.card-icon-wrapper', {
       y: -10,
       duration: 2.5,
       repeat: -1,
       yoyo: true,
       stagger: 0.2,
       ease: "sine.inOut"
    });

    // Orbital rotation (Hero-style moving elements)
    gsap.to('.orbit-path', {
      strokeDashoffset: -170, // Total circum approx 170
      duration: 3,
      repeat: -1,
      ease: "none",
      stagger: 0.2
    });

    gsap.to('.orbital-ring', {
      rotate: 360,
      duration: 10,
      repeat: -1,
      ease: "none"
    });
  };

  window.addEventListener('load', initServicesAnimations);
</script>
