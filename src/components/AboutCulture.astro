<section class="about-culture" id="culture">
  <!-- Decorative Background Blobs -->
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  
  <div class="container--smart">
    <!-- Section 1: Trusted Extension (Left Text, Right Image) -->
    <div class="culture-row">
      <div class="culture-text reveal-left">
        <h2 class="culture-title">
          A Trusted <span class="accent-wrap">Extension
            <svg class="accent-scribble" viewBox="0 0 100 20"><path d="M5 15 Q50 20 95 15" stroke="var(--color-primary)" stroke-width="3" fill="none" /></svg>
          </span> of Your Team.
        </h2>
        <p class="culture-desc">
          We work alongside your business, not outside of it. We integrate into the way you work and provide reliable support that feels like a natural part of your operations.
        </p>
      </div>
      <div class="culture-visual">
        <div class="circle-frame reveal-scale" style="--border-color: #4DD0E1;">
          <img src="/assets/lead-travis.png" alt="A Trusted Extension" />
        </div>
      </div>
    </div>

    <!-- Section 2: Reliable, Human Support (Left Image, Right Text) -->
    <div class="culture-row reverse">
      <div class="culture-text reveal-right">
        <h2 class="culture-title">Reliable, <span class="accent-wrap">Human
          <svg class="accent-scribble" viewBox="0 0 100 20"><path d="M5 15 Q50 20 95 15" stroke="var(--color-secondary)" stroke-width="3" fill="none" /></svg>
        </span> Support.</h2>
        <p class="culture-desc">
          We believe in real people and clear communication. Our focus is on doing things properly and building long-term relationships through consistent delivery.
        </p>
      </div>
      <div class="culture-visual">
        <div class="circle-frame reveal-scale" style="--border-color: #5b62ad;">
          <img src="/assets/sarah-sakara.png" alt="Human Support" />
        </div>
      </div>
    </div>

    <!-- Section 3: Built for Growth (Left Text, Right Image) -->
    <div class="culture-row">
      <div class="culture-text reveal-left">
        <h2 class="culture-title">Built for your <span class="accent-wrap">growth.
          <svg class="accent-scribble" viewBox="0 0 100 20"><path d="M5 15 Q50 20 95 15" stroke="var(--color-accent)" stroke-width="3" fill="none" /></svg>
        </span></h2>
        <p class="culture-desc">
          Our role is simple: to free you from the operational burden that holds you back. We help create the time and capacity needed for you to focus on moving your business forward.
        </p>
        <div class="cta-wrap">
          <a href="/contact" class="btn btn-black-pill">Let's talk about growth</a>
        </div>
      </div>
      <div class="culture-visual">
        <div class="circle-frame reveal-scale" style="--border-color: #5C60A6;">
          <img src="/assets/lead-niel.png" alt="Built for Growth" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-culture {
    padding: 6rem 0;
    background-color: #fdfcf6;
    overflow: hidden;
    position: relative;
  }

  /* Decorative Blobs */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    opacity: 0.15;
    pointer-events: none;
  }
  .blob-1 {
    width: 400px;
    height: 400px;
    background: var(--color-primary);
    top: 10%;
    right: -100px;
  }
  .blob-2 {
    width: 500px;
    height: 500px;
    background: var(--color-secondary);
    bottom: 5%;
    left: -150px;
    opacity: 0.1;
  }

  .container--smart {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    flex-direction: column;
    gap: 120px; 
    position: relative;
    z-index: 2;
  }

  .culture-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 100px;
  }

  .culture-row.reverse {
    direction: rtl; 
  }

  .culture-row.reverse .culture-text,
  .culture-row.reverse .culture-desc,
  .culture-row.reverse .culture-title {
    direction: ltr;
  }

  @media (max-width: 1024px) {
    .container--smart { padding: 0 1.5rem; gap: 80px; }
    .culture-row,
    .culture-row.reverse {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
      direction: ltr;
    }
  }

  .culture-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 500;
    line-height: 1.15;
    margin-bottom: 2rem;
    letter-spacing: -0.03em;
    color: #000;
  }

  .accent-wrap {
    position: relative;
    display: inline-block;
  }
  .accent-scribble {
    position: absolute;
    bottom: -8px;
    left: -5%;
    width: 110%;
    height: 20px;
    pointer-events: none;
    z-index: -1;
    opacity: 0.4;
  }

  .culture-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: #555;
    max-width: 480px;
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .culture-desc {
      margin: 0 auto;
    }
  }

  .cta-wrap {
    margin-top: 2.5rem;
  }

  /* Circular Visuals */
  .culture-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .circle-frame {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1/1;
    border-radius: 50%;
    border: 10px solid var(--border-color);
    overflow: hidden;
    position: relative;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.08); 
    background: #fff;
    opacity: 0;
    transform: scale(0.9) translateY(20px);
  }

  .circle-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Reveal logic */
  .reveal-left { opacity: 0; transform: translateX(-40px); }
  .reveal-right { opacity: 0; transform: translateX(40px); }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initAboutCulture = () => {
    const rows = document.querySelectorAll(".culture-row");

    rows.forEach((row, i) => {
      const text = row.querySelector('.reveal-left, .reveal-right');
      const image = row.querySelector('.reveal-scale');
      const scribble = row.querySelector('.accent-scribble path') as SVGPathElement;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: row,
          start: "top 85%",
        }
      });

      // 1. Animate Text Appearance
      if (text) {
        tl.to(text, {
          opacity: 1,
          x: 0,
          duration: 1.2,
          ease: "power4.out"
        });
      }

      // 2. Animate Image Appearance (Smooth scale & fade)
      if (image) {
        tl.to(image, {
          opacity: 1,
          scale: 1,
          y: 0,
          duration: 1.5,
          ease: "elastic.out(1, 0.75)" // Premium "pop"
        }, "-=0.8");
      }

      // 3. Animate Scribble
      if (scribble) {
        const length = scribble.getTotalLength();
        gsap.set(scribble, { strokeDasharray: length, strokeDashoffset: length });
        tl.to(scribble, {
          strokeDashoffset: 0,
          duration: 0.8,
          ease: "power2.inOut"
        }, "-=1");
      }
    });

    // Subtle floating for blooms
    gsap.to('.blob-1', {
      x: 50,
      y: 50,
      duration: 10,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
    gsap.to('.blob-2', {
      x: -60,
      y: -40,
      duration: 12,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
  };

  window.addEventListener("load", initAboutCulture);
</script>
