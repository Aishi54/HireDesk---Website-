---
const team = [
  {
    name: "Shabab",
    role: "Founder & Operations Partner",
    description: "Shabab leads the operational delivery of Hire Desk from Pakistan. He oversees team management, recruitment, training, systems and day-to-day delivery to ensure work is completed to a consistently high standard. A serial entrepreneur with experience building and operating multiple businesses across the UK.",
    image: "/assets/lead-travis.png",
    location: "Pakistan"
  },
  {
    name: "Rasool",
    role: "UK Managing Partner",
    description: "Rasool leads client relationships, onboarding and commercial strategy across the UK. With over 20 years experience in senior commercial roles, she works directly with clients to understand how their business operates and ensure Hire Desk delivers a solution that genuinely fits.",
    image: "/assets/sarah-sakara.png",
    location: "United Kingdom"
  }
];
---

<section class="team-section">
  <div class="container--wide">
    <div class="team-header reveal">
      <span class="label-text">Meet The Team</span>
      <h2 class="section-title">The Team Behind Hire Desk</h2>
      <p class="section-desc">
        Hire Desk is led by a hands-on team that combines UK leadership with operational delivery.
      </p>
    </div>

    <div class="team-grid">
      {team.map((member) => (
        <div class="team-card reveal">
          <div class="card-image-wrapper">
             <img src={member.image} alt={member.name} class="member-img" />
            <div class="location-tag">{member.location}</div>
          </div>
          <div class="card-content">
            <h3 class="member-name">{member.name}</h3>
            <p class="member-role">{member.role}</p>
            <p class="member-bio">{member.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: 8rem 0;
    background-color: #fdfcf6;
    position: relative;
    overflow: hidden;
  }

  /* Subtitle Accent */
  .team-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 100px;
    background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.1), transparent);
  }

  .container--wide {
    max-width: 900px; /* Even tighter for compactness */
    margin: 0 auto;
    padding: 0 2rem;
  }

  .team-header {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .label-text {
    font-size: 0.8rem;
    font-weight: 800;
    color: #5b62ad; 
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-title {
    font-size: clamp(2.2rem, 4vw, 2.8rem); /* Slightly smaller */
    font-weight: 700;
    line-height: 1.1;
    color: #000;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .section-desc {
    font-size: 1.1rem; /* Smaller */
    color: #444;
    max-width: 500px;
    line-height: 1.4;
    margin: 1rem auto 0;
    font-weight: 500;
    opacity: 0.7;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem; /* Tighter gap */
  }

  .team-card {
    background: #fff;
    border-radius: 32px; /* Slightly smaller radius */
    padding: 2rem; /* Reduced padding */
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 20px 60px rgba(0,0,0,0.03);
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
  }

  .team-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 40px 80px rgba(0,0,0,0.06);
  }

  .card-image-wrapper {
    width: 100px; /* Reduced from 140px */
    height: 100px;
    position: relative;
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    overflow: hidden;
    margin-bottom: 1.5rem; /* Reduced */
    background: linear-gradient(135deg, #54c6d7, #5b62ad);
    transition: all 0.6s ease;
  }

  .team-card:hover .card-image-wrapper {
    border-radius: 50%;
  }

  .member-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .location-tag {
    position: absolute;
    bottom: -4px; /* Tighter */
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    color: #fff;
    padding: 0.35rem 0.8rem;
    border-radius: 100px;
    font-size: 0.6rem; /* Smaller */
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .member-name {
    font-size: 1.4rem; /* Reduced from 2.2rem */
    font-weight: 800;
    color: #000;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
  }

  .member-role {
    font-size: 0.9rem; /* Reduced */
    font-weight: 700;
    color: #5b62ad; 
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .member-bio {
    font-size: 0.9rem; /* Reduced */
    line-height: 1.5;
    color: #666;
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .team-grid {
      grid-template-columns: 1fr;
      max-width: 380px; /* Tighter on mobile */
    }
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    gsap.to('.team-section .reveal', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '.team-section',
        start: "top 80%"
      }
    });

    // Label scribble animation
    const path = document.querySelector('.team-section .scribble-path');
    if (path instanceof SVGPathElement) {
       const length = path.getTotalLength();
       gsap.set(path, { strokeDasharray: length, strokeDashoffset: length });
       gsap.to(path, {
          strokeDashoffset: 0,
          duration: 1.2,
          ease: "power2.inOut",
          scrollTrigger: {
             trigger: '.team-section',
             start: "top 80%"
          }
       });
    }
  });
</script>
