---

---

<section class="about-hero">
  <div class="container--smart">
    <div class="hero-content">
      <div class="tagline-wrap reveal">
        <span class="tagline">Outsourcing+</span>
      </div>

      <h1 class="hero-title reveal">
        We’ve Decoded the Science of <span class="text-gradient"
          >Excellence.</span
        >
      </h1>

      <p class="hero-description reveal">
        At Hiredesk, only the most qualified 4-year and advanced degree holders
        make it onto your live-mandates. With an acceptance rate of 2%, our
        recruitment process is on par with Harvard.
      </p>

      <div class="hero-cta reveal">
        <a href="#culture" class="btn btn-black">Learn our culture</a>
      </div>
    </div>

    {/* Elegant Background Graphic - Moving Paths */}
    <div class="hero-visual reveal">
      <svg class="about-svg" viewBox="0 0 500 500" fill="none">
        <circle
          cx="250"
          cy="250"
          r="180"
          stroke="#000"
          stroke-width="0.5"
          opacity="0.1"></circle>
        <circle
          cx="250"
          cy="250"
          r="120"
          stroke="#000"
          stroke-width="0.5"
          opacity="0.1"></circle>

        {/* Animated brand paths */}
        <path class="flow-path purple" d="M250 70 A180 180 0 0 1 430 250"
        ></path>
        <path class="flow-path blue" d="M250 430 A180 180 0 0 1 70 250"></path>
        <path class="flow-path cyan" d="M130 250 A120 120 0 0 1 250 130"></path>

        {/* Logo Icon in center */}
        <g class="center-logo">
          <circle
            cx="250"
            cy="250"
            r="45"
            fill="white"
            stroke="#5C60A6"
            stroke-width="2.5"></circle>
          <path
            d="M240 240 L250 260 L265 230"
            stroke="#5C60A6"
            stroke-width="5"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </g>
      </svg>
    </div>
  </div>
</section>

<style>
  .about-hero {
    background-color: #fdfcf6;
    padding: 1.5rem 0 1rem; /* Minimized vertical space to pull content up */
    position: relative;
    overflow: hidden;
  }

  .container--smart {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 4rem;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 3rem;
  }

  @media (max-width: 1024px) {
    .container--smart {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
    .hero-content {
      order: 2;
    }
    .hero-visual {
      order: 1;
      transform: scale(0.8); /* Scale down visual on mobile */
    }
  }

  .tagline-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    margin-bottom: 0.75rem;
  }

  @media (max-width: 1024px) {
    .tagline-container { align-items: center; }
  }

  .tagline {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .tagline-underline {
    height: 1.5px;
    background: var(--color-primary);
    width: 20px;
    transform: scaleX(1);
    transform-origin: left;
  }

  .hero-title {
    font-size: clamp(1.4rem, 3vw, 2.1rem); /* Significantly smaller to fit in frame */
    line-height: 1.2;
    margin-bottom: 1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #000;
  }

  .text-gradient {
    color: var(--color-primary);
  }

  .hero-description {
    font-size: 0.9rem; /* Denser, smarter density */
    line-height: 1.45;
    color: #444;
    margin-bottom: 1.5rem;
    max-width: 460px;
    font-weight: 400;
  }

  @media (max-width: 1024px) {
    .hero-description {
      margin: 0 auto 3rem;
    }
  }

  /* Visual Graphic */
  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .about-svg {
    width: 100%;
    max-width: 450px;
    height: auto;
    overflow: visible;
  }

  .flow-path {
    fill: none;
    stroke-width: 12;
    stroke-linecap: round;
    opacity: 0.9;
  }

  .purple {
    stroke: var(--color-primary);
  }
  .blue {
    stroke: var(--color-secondary);
  }
  .cyan {
    stroke: var(--color-accent);
  }

  /* Animations */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>

<script>
  import gsap from "gsap";

  const initAboutHero = () => {
    // 1. Reveal Text Items
    gsap.to(".hero-content .reveal, .hero-visual", {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power3.out",
    });

    // 2. Loop paths
    const paths = document.querySelectorAll(".flow-path");
    paths.forEach((path, i) => {
      const length = (path as SVGPathElement).getTotalLength();
      gsap.set(path, { strokeDasharray: length, strokeDashoffset: length });

      gsap.to(path, {
        strokeDashoffset: -length,
        duration: 4 + i,
        repeat: -1,
        ease: "none",
        delay: i * 0.5,
      });
    });

    // 3. Center logo float
    gsap.to(".center-logo", {
      y: -15,
      duration: 3,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
    });
  };

  window.addEventListener("load", initAboutHero);
</script>
