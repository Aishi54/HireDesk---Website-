<div class="floating-container left">
  <!-- Avatar 1 -->
  <div class="float-item avatar a1">
    <div class="ring-gradient"></div>
    <div class="avatar-inner">
      <img src="/assets/lead-niel.png" alt="" />
    </div>
    <div class="float-icon chat">
      <svg viewBox="0 0 40 40"><path d="M5 5 H30 V25 H15 L5 35 Z" stroke="black" stroke-width="2" fill="white"/></svg>
    </div>
  </div>

  <!-- Icon 1: Slack -->
  <div class="float-item icon i1">
    <div class="yellow-circle">
      <svg viewBox="0 0 24 24" fill="black"><path d="M6 15a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm0-9a2 2 0 1 0 0 4V6zm9 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm0 9a2 2 0 1 0 0 4v-4z"/></svg>
    </div>
  </div>

  <!-- Avatar 2 -->
  <div class="float-item avatar a2">
    <div class="ring-gradient"></div>
    <div class="avatar-inner">
      <img src="/assets/lead-travis.png" alt="" />
    </div>
  </div>

  <!-- Icon 2: Chat -->
  <div class="float-item icon i2">
    <div class="yellow-circle">
      <div class="dots"><span></span><span></span><span></span></div>
    </div>
  </div>

  <!-- Avatar 3 -->
  <div class="float-item avatar a3">
    <div class="ring-gradient"></div>
    <div class="avatar-inner">
      <img src="/assets/sarah-sakara.png" alt="" />
    </div>
    <div class="float-icon play">
      <svg viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" stroke="black" stroke-width="2" fill="white"/><path d="M15 12 L28 20 L15 28 Z" fill="black"/></svg>
    </div>
  </div>
</div>

<style>
  .floating-container {
    position: absolute;
    width: 380px;
    height: 480px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .left { left: 40px; }
  .right { right: 40px; }

  .float-item {
    position: absolute;
    transition: transform 0.3s ease;
  }

  /* Avatar styles */
  .avatar {
    width: 120px;
    height: 120px;
  }

  .avatar-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #fff;
    padding: 8px;
    overflow: hidden;
    position: relative;
    z-index: 2;
  }

  .avatar-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .ring-gradient {
    position: absolute;
    top: -4px; right: -4px; bottom: -4px; left: -4px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7B61FF, #EBE6FF);
    z-index: 1;
    opacity: 0.6;
  }

  /* Icon styles */
  .icon {
    width: 60px;
    height: 60px;
  }

  .yellow-circle {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background-color: #F8F4E1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 15px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }

  .dots { display: flex; gap: 4px; }
  .dots span { width: 4px; height: 4px; background: black; border-radius: 50%; }

  /* Positions */
  .a1 { top: 0; left: 100px; }
  .a2 { top: 200px; left: 0; }
  .a3 { top: 350px; left: 180px; }

  .i1 { top: 120px; left: 0; }
  .i2 { top: 220px; left: 240px; }

  /* Floating Hand Icons */
  .float-icon {
    position: absolute;
    width: 50px;
    height: 50px;
    z-index: 10;
  }

  .chat { top: -30px; left: -20px; }
  .play { top: 40px; right: -40px; }

  @media (max-width: 1200px) {
    .floating-container { display: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  
  const items = document.querySelectorAll('.float-item');
  items.forEach((item, i) => {
    gsap.to(item, {
      y: '+=20',
      x: '+=10',
      duration: 3 + i * 0.5,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: i * 0.2
    });
  });
</script>
