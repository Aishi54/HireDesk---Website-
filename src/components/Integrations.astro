---
const techLogos = [
  { name: 'Trust' },
  { name: 'Quality' },
  { name: 'Clear Communication' },
  { name: 'Long-term Relationships' },
  { name: 'Doing things properly' }
];
---

<section class="integrations-marquee-section" id="integrations">
  <!-- Dynamic Brand Strips (Top) -->
  <div class="brand-strips-top">
    <div class="strip strip-1" data-color="purple">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0 120 C 480 20, 960 20, 1440 120 L 1440 120 L 0 120 Z" fill="#5b62ad"/></svg>
    </div>
    <div class="strip strip-2" data-color="blue">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0 120 C 480 60, 960 60, 1440 120 L 1440 120 L 0 120 Z" fill="#6484c2"/></svg>
    </div>
  </div>

  <div class="container--wide">
    <div class="integrations-header reveal">
      <div class="header-content-wrap">
        <div class="label-box">
          <span class="label-text">OUR APPROACH</span>
          <svg class="label-scribble" viewBox="0 0 100 20">
            <path d="M5 15 Q50 20 95 15" stroke="black" stroke-width="2" fill="none" class="scribble-path"></path>
          </svg>
        </div>
        <h2 class="section-title">
          We believe in trust, quality, <br/>
          and doing things properly.
          <svg class="title-scribble" viewBox="0 0 300 20">
            <path d="M10 12 Q150 18 290 12" stroke="black" stroke-opacity="0.1" stroke-width="3" fill="none" class="scribble-path"></path>
          </svg>
        </h2>
      </div>
      <div class="header-action reveal">
        <a href="#" class="btn btn-black-pill">Simple, reliable support.</a>
      </div>
    </div>

    <!-- Clean Marquee -->
    <div class="marquee-reveal-container reveal">
      <div class="tech-marquee">
        <div class="marquee-content marquee-move">
          {[...techLogos, ...techLogos].map((logo) => (
            <div class="logo-item" title={logo.name}>
              <span class="logo-name">{logo.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .integrations-marquee-section {
    background: var(--bg-primary); /* Use global off-white background */
    padding: 0 0 1rem 0;
    position: relative;
    overflow: hidden;
  }

  .brand-strips-top {
    position: relative;
    width: 100%;
    height: 120px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    margin-bottom: 0.5rem;
  }

  .strip {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
  }

  /* Layering the strips */
  .strip-1 { z-index: 2; }
  .strip-2 { z-index: 1; }

  .strip svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .container--wide {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 4rem;
    text-align: center;
  }

  /* Header (Screenshot Style) */
  .integrations-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-content-wrap {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 2rem;
  }

  .label-box {
    position: relative;
    padding-top: 0.5rem;
  }

  .label-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    text-transform: capitalize;
    letter-spacing: 0.05em;
  }

  .label-scribble {
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 12px;
    pointer-events: none;
  }

  .section-title {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 500;
    line-height: 1.05;
    color: #000;
    position: relative;
    letter-spacing: -3.0333px;
    margin: 0;
  }

  .title-scribble {
    position: absolute;
    bottom: -15px;
    left: 0;
    width: 100%;
    height: 20px;
    pointer-events: none;
    opacity: 0.15;
  }

  /* Clean Marquee */
  .tech-marquee {
    display: flex;
    overflow: hidden;
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .marquee-content {
    display: flex;
    gap: 8rem;
    padding: 2rem 0;
    align-items: center;
    white-space: nowrap;
    animation: marquee-move 40s linear infinite;
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #000;
    opacity: 0.9;
    transition: all 0.3s ease;
  }

  .logo-name {
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    font-weight: 900;
    letter-spacing: -0.01em;
    font-family: var(--font-main);
  }

  @keyframes marquee-move {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 1024px) {
    .integrations-marquee-section { padding: 3.5rem 0 4rem; } 
    .container--wide { padding: 0 1.5rem; text-align: center; }
    .integrations-header { text-align: center; margin-bottom: 2rem; }
    h2 { font-size: 1.8rem; } /* Perfect smart scale on mobile */
    .marquee-content { gap: 4rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initIntegrationsAnimations = () => {
    // Brand strips reveal animation
    const timeline = gsap.timeline({
      scrollTrigger: {
        trigger: '.integrations-marquee-section',
        start: 'top 70%',
        toggleActions: 'play none none none'
      }
    });

    timeline.from('.brand-strips-top .strip-1', {
      xPercent: -100,
      duration: 1.4,
      ease: 'power3.out'
    });

    timeline.from('.brand-strips-top .strip-2', {
      xPercent: 100,
      duration: 1.4,
      ease: 'power3.out'
    }, '-=1.0');

    gsap.to('.reveal', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power2.out",
      scrollTrigger: {
        trigger: '.integrations-marquee-section',
        start: "top 60%"
      }
    });
  };

  window.addEventListener('load', initIntegrationsAnimations);
</script>
