---
const caseStudies = [
  {
    category: "Founder Story",
    title: "How a founder-led business became the bottleneck to its own growth",
    teaser: "A successful multi-store business owner found himself overwhelmed by day-to-day operations, until his model became unsustainable.",
    link: "/case-studies/founder-bottleneck",
    color: "#5b62ad", // Scampi
    image: "https://images.unsplash.com/photo-1507679799987-c73779587ccf?q=80&w=2071&auto=format&fit=crop"
  },
  {
    category: "SME Scaling",
    title: "Bringing structure and consistency to a scaling business",
    teaser: "As internal processes struggled to keep up with growth, Hire Desk introduced structured support to free the leadership team.",
    link: "/case-studies/scaling-systems",
    color: "#54c6d7", // Viking
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop"
  },
  {
    category: "Hiring Strategy",
    title: "A flexible alternative to building an in-house team",
    teaser: "How an SME avoided the high costs of local hiring by integrating a tailored, high-performing outsourced support model.",
    link: "/case-studies/hiring-alternative",
    color: "#6484c2", // Danube
    image: "https://images.unsplash.com/photo-1521737711867-e3b97375f902?q=80&w=2070&auto=format&fit=crop"
  }
];
---

<section class="case-studies-section">
  <div class="container--wide">
    <div class="section-header text-center reveal">
      <div class="label-box">
        <span class="label-text">Success Stories</span>
        <svg class="label-scribble" viewBox="0 0 100 20">
          <path d="M5 15 Q50 20 95 15" stroke="currentColor" stroke-width="2" fill="none"></path>
        </svg>
      </div>
      <h2 class="section-title">Practical Success in Action</h2>
      <p class="section-desc">
        Explore how we've helped businesses buy back their time and scale without the friction of traditional administration.
      </p>
    </div>

    <div class="case-studies-grid">
      {caseStudies.map((study, i) => (
        <div class="study-card reveal" style={`--accent: ${study.color}; --delay: ${i * 0.1}s;`}>
          <div class="card-image-wrap">
            <img src={study.image} alt={study.title} />
            <span class="category-tag">{study.category}</span>
          </div>
          <div class="card-content">
            <h3 class="study-title">{study.title}</h3>
            <p class="study-teaser">{study.teaser}</p>
            <a href={study.link} class="btn-read">
              Read Case Study
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .case-studies-section {
    padding: 100px 0;
    background-color: #FDFCF6;
    position: relative;
    overflow: hidden;
  }

  .container--wide {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    margin-bottom: 5rem;
  }

  .label-box {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    color: var(--accent, #5b62ad);
    margin-bottom: 1rem;
  }

  .label-text {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .label-scribble {
    width: 60px;
    height: 12px;
    margin-top: -4px;
    opacity: 0.6;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #000;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .section-desc {
    font-size: 1.1rem;
    color: #555;
    max-width: 600px;
    margin: 1.5rem auto 0;
    line-height: 1.6;
  }

  .case-studies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem; /* Tighter gap */
  }

  .study-card {
    background: #fff;
    border-radius: 20px; /* Slightly smaller radius */
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.06);
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .study-card:hover {
    transform: translateY(-8px); /* Subtle lift */
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    border-color: var(--accent);
  }

  .card-image-wrap {
    position: relative;
    height: 160px; /* SHRUNK from 240px */
    overflow: hidden;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .study-card:hover .card-image-wrap img {
    transform: scale(1.05);
  }

  .category-tag {
    position: absolute;
    top: 15px;
    left: 15px;
    background: var(--accent);
    color: #fff;
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    z-index: 2;
  }

  .card-content {
    padding: 1.5rem; /* COMPACT padding */
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .study-title {
    font-size: 1.1rem; /* SHRUNK from 1.35rem */
    font-weight: 700;
    line-height: 1.3;
    color: #000;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .study-teaser {
    font-size: 0.88rem; /* SHRUNK from 1rem */
    color: #555;
    line-height: 1.45;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .btn-read {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #000;
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .btn-read svg {
    transition: transform 0.3s ease;
  }

  .btn-read:hover {
    gap: 1.25rem;
  }

  .btn-read:hover svg {
    transform: translateX(5px);
  }

  @media (max-width: 1024px) {
    .case-studies-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .case-studies-grid {
      grid-template-columns: 1fr;
    }
    .section-title {
      font-size: 2.5rem;
    }
    .container--wide {
      padding: 0 1.5rem;
    }
  }
</style>
