---
const steps = [
  {
    number: 1,
    title: "Deep dive into your goals and team structure.",
    content: "We take the time to understand your unique needs and goals. Our talent becomes an extension of your team, supporting your customer experience initiatives within your strategic direction, timelines and budgets."
  },
  {
    number: 2,
    title: "We design a customized solution for you.",
    content: "Our experts craft a bespoke operational framework tailored specifically to your business model, ensuring seamless integration and maximum efficiency."
  },
  {
    number: 3,
    title: "Review and assemble your dream team.",
    content: "Hand-select top-tier professionals from our elite talent pool who perfectly match your culture and technical requirements."
  },
  {
    number: 4,
    title: "We'll implement a dedicated training program.",
    content: "Before going live, your team undergoes rigorous, brand-specific training to master your processes, tools, and brand voice."
  },
  {
    number: 5,
    title: "Go Live & schedule check-ins!",
    content: "Launch your operation with confidence. We provide continuous support and regular performance reviews to ensure all KPIs are exceeded."
  }
];
---

<section class="operational-steps">
  <div class="container--wide">
    <div class="steps-header reveal">
      <h2>Launch in 5 easy steps</h2>
      <p>We source, train, and assemble your new team in as little as 2 weeks. Once you go live, we continuously work to ensure you hit KPIs.</p>
    </div>

    <div class="steps-layout">
      <!-- Left: Interactive Accordion / Slider -->
      <div class="steps-slider-viewport">
        <!-- Mobile Navigation Arrows (STRICT MOBILE ONLY) -->
        <div class="mobile-only">
          <div class="mobile-nav-arrows">
            <button class="nav-arrow prev-btn" aria-label="Previous">
              <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button class="nav-arrow next-btn" aria-label="Next">
              <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>
        </div>

        <div class="steps-list reveal" id="stepsList">
          {steps.map((step, i) => (
            <div class={`step-item ${i === 0 ? 'active' : ''}`} data-index={i}>
              <div class="step-header">
                <span class="step-title">{step.number}. {step.title}</span>
                <div class="step-toggle desktop-only">
                  <span class="plus">+</span>
                  <span class="minus">-</span>
                </div>
              </div>
              <div class="step-content">
                <div class="content-inner">
                  <p>{step.content}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Geometric Graphic -->
      <div class="steps-graphic reveal">
        <div class="graphic-container">
           {/* Honeycomb grid mirroring the Hero Section's shape */}
           <svg viewBox="0 0 400 400" class="geometric-svg" id="stepsGeometric">
              <g class="bg-grid">
                {Array.from({ length: 16 }).map((_, i) => {
                  const row = Math.floor(i / 4);
                  const col = i % 4;
                  const x = 70 + col * 85 + (row % 2 === 0 ? 0 : 42);
                  const y = 80 + row * 75;
                  
                  return (
                    <circle 
                      cx={x} cy={y} 
                      r={38} 
                      class="dot-bg"
                      fill="none"
                      stroke="#F1E6CC"
                      stroke-width="1.8"
                    />
                  );
                })}
              </g>

              {/* Solid Reveal Layer */}
              <g class="solid-layer">
                 {Array.from({ length: 16 }).map((_, i) => {
                  const row = Math.floor(i / 4);
                  const col = i % 4;
                  const x = 70 + col * 85 + (row % 2 === 0 ? 0 : 42);
                  const y = 80 + row * 75;
                  return (
                    <circle 
                      cx={x} cy={y} 
                      r={38} 
                      id={`dot-solid-${i}`}
                      class="dot-solid"
                      fill="transparent"
                      stroke="none"
                    />
                  );
                })}
              </g>

              {/* Animated Snakes Layer */}
              <g class="snake-layer">
                {Array.from({ length: 16 }).map((_, i) => {
                  const row = Math.floor(i / 4);
                  const col = i % 4;
                  const cx = 70 + col * 85 + (row % 2 === 0 ? 0 : 42);
                  const cy = 80 + row * 75;
                  
                  return (
                    <path 
                      class="step-snake" 
                      id={`step-snake-${i}`}
                      d={`M ${cx} ${cy - 38} A 38 38 0 1 1 ${cx} ${cy + 38}`}
                      stroke="none"
                      stroke-width="10"
                      stroke-linecap="round"
                      fill="none"
                    />
                  );
                })}
              </g>
           </svg>
        </div>
      </div>
    </div>

    <!-- Centered CTA -->
    <div class="steps-cta-center reveal">
      <button class="btn-smart-black">Book a Meeting</button>
    </div>
  </div>
</section>

<style>
  .operational-steps {
    background-color: #FDFCF6;
    padding: 3.5rem 0;
    overflow: hidden;
  }

  .container--wide {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  /* Header */
  .steps-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 500;
    margin-bottom: 0.6rem;
    color: #000;
  }

  .steps-header p {
    font-size: 1rem;
    color: #666;
    line-height: 1.4;
  }

  /* Layout */
  .steps-layout {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 1024px) {
    .steps-layout { grid-template-columns: 1fr; gap: 4rem; }
    .steps-graphic { order: -1; }
    .graphic-container { margin: 0 auto; }
    .step-header { text-align: center; justify-content: center; }
    .step-title { font-size: 1.1rem; }
  }

  /* Accordion */
  .steps-slider-viewport {
    position: relative;
    width: 100%;
  }

  /* Desktop Grid */
  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  /* Navigation Arrows - Strictly hidden by default (Desktop) */
  .mobile-nav-arrows {
    display: none !important;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .nav-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #000;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
  }

  .nav-arrow:active { transform: scale(0.9); }

  @media (max-width: 1024px) {
    .steps-layout { 
      grid-template-columns: 1fr; 
      gap: 3rem; 
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .steps-header { text-align: center; }
    
    .steps-slider-viewport {
      overflow: hidden;
      width: 100%;
      padding: 0 1rem;
    }

    .steps-list {
      flex-direction: row;
      gap: 1.25rem;
      width: max-content;
      transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }
    
    .mobile-nav-arrows { display: flex !important; } /* Force show on mobile */
    .desktop-only { display: none !important; }

    .step-item {
      flex: 0 0 280px; 
      width: 280px;
      padding-bottom: 1.25rem;
      text-align: center;
    }
    .step-header {
      justify-content: center;
      padding: 1.5rem 1.25rem 0.5rem;
    }
    .step-content {
      max-height: none !important;
      opacity: 1 !important;
    }
    .content-inner {
      padding: 0 1.25rem;
    }
    .content-inner p {
      font-size: 0.95rem;
      line-height: 1.5;
      color: #555;
    }
    .steps-graphic { order: -1; transform: scale(0.9); }
  }

  /* Accordion (Desktop Only Logic) */
  .step-item {
    background: #fff;
    border: 1.2px solid rgba(0,0,0,0.06); 
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .step-header {
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .step-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #000;
  }

  .step-toggle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #000;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    position: relative;
    flex-shrink: 0;
  }

  .plus, .minus {
    position: absolute;
    transition: opacity 0.3s, transform 0.3s;
  }

  /* Reset toggle visibility for Desktop */
  .step-item.active .plus { opacity: 0; transform: rotate(90deg); }
  .step-item.active .minus { opacity: 1; transform: rotate(0); }
  .step-item:not(.active) .minus { opacity: 0; transform: rotate(-90deg); }
  .step-item:not(.active) .plus { opacity: 1; transform: rotate(0); }

  .step-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .step-item.active .step-content {
    max-height: 200px; /* Only active on desktop */
  }

  .content-inner {
    padding: 0 1.5rem 1.5rem;
  }

  .content-inner p {
    font-size: 0.95rem;
    line-height: 1.5;
    color: #333;
  }

  /* CTA */
  .steps-cta-center {
    margin-top: 4rem; /* More space for global centering */
    text-align: center;
    width: 100%;
  }

  /* Global Visibility Utilities */
  .mobile-only {
    display: none !important;
  }

  @media (max-width: 1024px) {
    .mobile-only {
      display: block !important;
    }
  }

  .btn-smart-black {
    background: #000;
    color: #fff;
    padding: 0.75rem 2.8rem; /* Bolder button width */
    border-radius: 100px;
    font-size: 0.95rem; 
    font-weight: 800;
    border: none;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  /* Graphic */
  .graphic-container {
    width: 100%;
    max-width: 360px;
    position: relative;
    margin-left: auto;
  }

  .geometric-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .step-snake {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .dot-solid {
    transition: opacity 0.6s ease;
  }

  /* Reveal */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initStepsGraphic = () => {
    // Official Branding Colors
    const stepColors = ['#FFDC00', '#4DD0E1', '#738AC9', '#5C60A6', '#FF4081'];
    const items = document.querySelectorAll('.step-item');
    const snakes = document.querySelectorAll('.step-snake');
    const solidDots = document.querySelectorAll('.dot-solid');
    let currentIndex = 0; // Shared state for slider and desktop

    // Reveal animations
    gsap.to('.operational-steps .reveal', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      scrollTrigger: {
        trigger: '.operational-steps',
        start: "top 75%"
      }
    });

    // 1. Initial State for Snakes
    snakes.forEach((snake, i) => {
      const path = snake as SVGPathElement;
      const length = path.getTotalLength();
      gsap.set(path, { strokeDasharray: `50 ${length}`, strokeDashoffset: length });
    });

    // 2. Continuous Living Animation
    gsap.to('.dot-bg', {
       scale: 1.05,
       duration: 4,
       repeat: -1,
       yoyo: true,
       stagger: { amount: 1.5, from: "random" },
       ease: "sine.inOut"
    });

    // 3. Selection Logic
    const updateGraphic = (idx: number) => {
      currentIndex = idx; // Link slider index to graphic
      const color = stepColors[idx];

      items.forEach((item, i) => {
        if (i === idx) {
           gsap.to(item, { backgroundColor: `${color}20`, borderColor: color, duration: 0.4 });
        } else {
           gsap.to(item, { backgroundColor: '#fff', borderColor: 'rgba(0,0,0,0.06)', duration: 0.4 });
        }
      });

      // Animate solid fills and snakes
      solidDots.forEach((dot, i) => {
         const isSelected = i % 5 === idx || (i + idx) % 4 === 0;
         const path = snakes[i] as SVGPathElement;
         const length = path.getTotalLength();

         if (isSelected) {
            gsap.to(dot, { 
               fill: color, 
               opacity: 0.15, 
               scale: 1, 
               duration: 0.8,
               ease: "power2.out"
            });
            
            gsap.killTweensOf(path);
            gsap.set(path, { stroke: color, opacity: 0.95 });
            gsap.fromTo(path, 
               { strokeDashoffset: length }, 
               { strokeDashoffset: -50, duration: 2.5, repeat: -1, ease: "linear", delay: Math.random() * 0.5 }
            );
         } else {
            gsap.to(dot, { fill: 'transparent', opacity: 0, duration: 0.5 });
            gsap.to(path, { opacity: 0, duration: 0.5 });
         }
      });
    };

    // Mobile Slider Logic
    const initStepsSlider = () => {
      const sliderList = document.getElementById('stepsList');
      const prevBtn = document.querySelector('.prev-btn');
      const nextBtn = document.querySelector('.next-btn');

      if (!sliderList || !prevBtn || !nextBtn) return;

      const updateSliderUI = () => {
        if (window.innerWidth > 1024) {
          gsap.set(sliderList, { x: 0 });
          return;
        }

        const cardWidth = 280;
        const gap = 20; // 1.25rem
        const moveX = -(currentIndex * (cardWidth + gap));

        gsap.to(sliderList, {
          x: moveX,
          duration: 0.6,
          ease: "power2.out"
        });

        // Update button visual state
        (prevBtn as HTMLElement).style.opacity = currentIndex === 0 ? '0.3' : '1';
        (nextBtn as HTMLElement).style.opacity = currentIndex === items.length - 1 ? '0.3' : '1';
      };

      prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
          currentIndex--;
          updateSliderUI();
          updateGraphic(currentIndex);
        }
      });

      nextBtn.addEventListener('click', () => {
        if (currentIndex < items.length - 1) {
          currentIndex++;
          updateSliderUI();
          updateGraphic(currentIndex);
        }
      });

      window.addEventListener('resize', updateSliderUI);
    };

    items.forEach((item, i) => {
      item.addEventListener('click', () => {
        if (window.innerWidth > 1024) {
          items.forEach(el => el.classList.remove('active'));
          item.classList.add('active');
        }
        updateGraphic(i);
      });
    });

    initStepsSlider();
    // Initial Trigger
    updateGraphic(0);
  };

  window.addEventListener('load', () => {
     initStepsGraphic();
  });
</script>
