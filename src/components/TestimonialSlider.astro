---
interface Testimonial {
  image: string;
  logo: string;
  quote: string;
  author: string;
  role: string;
}

const testimonials: Testimonial[] = [
  {
    image: '/testimonial_portrait_male.png', 
    logo: 'Outschool',
    quote: "Everyone on my Hugo team could have successfully interviewed for our team in Brooklyn. That is important to me. We're getting top-tier talent without the big city price tag.",
    author: 'Chris M.',
    role: 'Chief Operating Officer'
  },
  {
    image: '/testimonial_portrait_female.png', 
    logo: 'Sakara',
    quote: "hiredesk brought real expertise and flexibility to our operation. They helped us improve response times and satisfaction.",
    author: 'Sarah S.',
    role: 'VP of Growth'
  }
];
---

<section class="testimonial-slider-section">
  <div class="container">
    <div class="slider-overflow">
      <div class="testimonials-track" id="testimonialTrack">
        {testimonials.map((t, i) => (
          <div class="testimonial-slide" data-index={i}>
            <div class="slide-inner">
              <!-- Left: Image with yellow circles (Desktop Only) -->
              <div class="image-box desktop-only">
                <div class="main-circle">
                  <div class="image-wrapper">
                    <img src={t.image} alt={t.author} />
                  </div>
                  <div class="small-circle"></div>
                </div>
              </div>

              <!-- Right: Content -->
              <div class="content-box">
                <div class="logo-wrap">
                  <span class="company-name">{t.logo}</span>
                </div>
                
                <div class="quote-wrap">
                  <span class="quote-icon open desktop-only">
                     <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><path d="M15 15Q10 15 10 20M10 20Q10 25 15 25" stroke="black" stroke-width="4" stroke-linecap="round"/></svg>
                  </span>
                  
                  <p class="quote-text">{t.quote}</p>
                  
                  <span class="quote-icon close desktop-only">
                     <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><path d="M25 15Q30 15 30 20M30 20Q30 25 25 25" stroke="black" stroke-width="4" stroke-linecap="round"/></svg>
                  </span>
                </div>

                <div class="author-meta">
                  <div class="image-box mobile-only">
                    <div class="main-circle small">
                      <div class="image-wrapper">
                        <img src={t.image} alt={t.author} />
                      </div>
                    </div>
                  </div>
                  <div class="name-role-group">
                    <span class="name">{t.author}</span>
                    <span class="role">{t.role}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom Progress Bar -->
    <div class="progress-bar-wrap">
       <div class="progress-bar">
         {testimonials.map((_, i) => (
           <div class="progress-segment" data-index={i}>
              <div class="progress-fill"></div>
           </div>
         ))}
       </div>
    </div>
  </div>
</section>

<style>
  .testimonial-slider-section {
    background-color: #FDFCF6;
    padding: 6rem 0;
    overflow: hidden;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .testimonials-track {
    display: flex;
    width: 100%;
    will-change: transform;
  }

  .testimonial-slide {
    flex: 0 0 100%;
    width: 100%;
    padding: 0 2rem;
  }

  .slide-inner {
    display: flex;
    align-items: center;
    gap: 8rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Image Box (Desktop) */
  .image-box.desktop-only {
    flex: 0 0 240px;
    display: flex;
    justify-content: center;
    position: relative;
  }

  .main-circle {
    width: 240px;
    height: 240px;
    border-radius: 50%;
    border: 6px solid #FFDC00;
    position: relative;
    background: #E0F7FA;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .main-circle.small {
    width: 60px;
    height: 60px;
    border-width: 2px;
  }

  .image-wrapper {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .main-circle:not(.small) .image-wrapper img {
    width: 110%;
    height: 110%;
    transform: translateY(10%);
  }

  .small-circle {
    position: absolute;
    bottom: 20px;
    right: -10px;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: #FFDC00;
    z-index: 10;
    border: 6px solid #FDFCF6;
  }

  /* Content */
  .content-box {
    flex: 1;
    text-align: left;
  }

  .logo-wrap {
    margin-bottom: 2rem;
  }

  .company-name {
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
  }

  .quote-wrap {
    margin-bottom: 3rem;
    display: flex;
    align-items: center;
  }

  .quote-icon {
    flex-shrink: 0;
    opacity: 0.9;
  }
  .quote-icon.open { margin-right: 2rem; }
  .quote-icon.close { margin-left: 2rem; }

  .quote-text {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 500;
    line-height: 1.4;
    color: #000;
    letter-spacing: -0.01em;
  }

  .author-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .name { font-weight: 800; font-size: 1.3rem; color: #000; margin-bottom: 0.2rem; }
  .role { font-size: 1.05rem; color: #666; font-weight: 600; }

  .name-role-group {
    display: flex;
    flex-direction: column;
  }

  /* Progress Bar */
  .progress-bar-wrap {
    display: flex;
    justify-content: center;
    margin-top: 4rem;
  }

  .progress-bar {
    display: flex;
    height: 8px;
    width: 450px;
    gap: 8px;
    border-radius: 20px;
    overflow: hidden;
    background-color: #EBEBEB;
  }

  .progress-segment {
    flex: 1;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background-color: #FFDC00;
    transform: translateX(-100%);
  }

  .progress-segment.past .progress-fill {
    transform: translateX(0);
    background-color: #000;
  }

  /* Utility */
  .mobile-only { display: none; }

  @media (max-width: 1024px) {
    .testimonial-slider-section { padding: 3rem 0; }
    .container { padding: 0 1.5rem; }
    .desktop-only { display: none !important; }
    .mobile-only { display: flex !important; }

    .slide-inner {
      flex-direction: column;
      background: #fff;
      padding: 2.5rem 1.5rem; /* More generous padding */
      border-radius: 16px;
      gap: 1.5rem; /* Balanced gap */
      max-width: 380px; /* Slightly wider */
      border: 1px solid rgba(0,0,0,0.06);
      box-shadow: 0 5px 20px rgba(0,0,0,0.02);
      text-align: center; /* FULL CENTER */
      align-items: center; /* FULL CENTER */
      margin: 0 auto;
    }
    .quote-text { 
      font-size: 1.15rem; 
      text-align: center; 
      line-height: 1.4;
    }
    .logo-wrap { margin-bottom: 0.75rem; display: flex; justify-content: center; }
    .quote-wrap { 
      margin-bottom: 1.5rem; 
      justify-content: center;
      width: 100%;
    }
    .author-meta {
      border-top: 1px solid rgba(0,0,0,0.06);
      padding-top: 1.5rem;
      gap: 1rem;
      width: 100%;
      justify-content: center; /* FULL CENTER */
      text-align: center;
    }
    .progress-bar { width: 100%; max-width: 260px; height: 6px; }
    .progress-bar-wrap { margin-top: 3rem; }
  }
</style>

<script>
  import gsap from 'gsap';

  class TestimonialSlider {
    section: HTMLElement | null;
    track: HTMLElement | null;
    slides: HTMLElement[];
    fills: HTMLElement[];
    segments: HTMLElement[];
    currentIndex: number;
    duration: number;

    constructor() {
      this.section = document.querySelector('.testimonial-slider-section');
      if (!this.section) {
        this.track = null;
        this.slides = [];
        this.fills = [];
        this.segments = [];
        this.currentIndex = 0;
        this.duration = 5; // seconds
        return;
      }

      this.track = this.section.querySelector('#testimonialTrack');
      this.slides = Array.from(this.section.querySelectorAll('.testimonial-slide'));
      this.fills = Array.from(this.section.querySelectorAll('.progress-fill'));
      this.segments = Array.from(this.section.querySelectorAll('.progress-segment'));
      this.currentIndex = 0;
      this.duration = 5;

      this.init();
    }

    init() {
      if (this.slides.length === 0) return;
      this.animateNext();
    }

    animateNext() {
      const fill = this.fills[this.currentIndex];
      const segment = this.segments[this.currentIndex];

      // Reset segment classes
      this.segments.forEach((seg, i) => {
         if (i < this.currentIndex) seg.classList.add('past');
         else seg.classList.remove('past');
      });

      // Animate the fill
      gsap.fromTo(fill, 
        { x: "-100%" }, 
        { 
          x: "0%", 
          duration: this.duration, 
          ease: "none",
          onComplete: () => {
            this.currentIndex = (this.currentIndex + 1) % this.slides.length;
            
            // If we looped back to 0, clear all past classes
            if (this.currentIndex === 0) {
               this.segments.forEach(seg => seg.classList.remove('past'));
               this.fills.forEach(f => gsap.set(f, { x: "-100%" }));
            }

            // Move the track
            gsap.to(this.track, {
               x: `-${this.currentIndex * 100}%`,
               duration: 0.8,
               ease: "power2.inOut"
            });

            this.animateNext();
          }
        }
      );
    }
  }

  window.addEventListener('load', () => {
    new TestimonialSlider();
  });
</script>
