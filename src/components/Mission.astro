<section class="mission-section">
  <!-- Top Curve -->
  <div class="curve-top">
    <svg viewBox="0 0 1440 140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 140 C 480 0, 960 0, 1440 140 Z" fill="#5b62ad"></path>
    </svg>
  </div>

  <div class="mission-container">
    <div class="container--wide">
      <!-- Main Title with Scribbles -->
      <div class="mission-header reveal">
        <h2 class="mission-title">
          <span class="relative-word">
            Your
            <svg class="word-scribble underline" viewBox="0 0 100 20"
              ><path
                d="M5 15 Q50 20 95 15"
                stroke="#fff"
                stroke-width="3"
                fill="none"
                class="scribble-path"></path></svg
            >
          </span>
          <span class="relative-word">
            success
            <svg class="word-scribble arrow-up" viewBox="0 0 40 40"
              ><path
                d="M20 35 Q15 20 25 5 M25 5 L15 15 M25 5 L35 12"
                stroke="#fff"
                stroke-width="2.5"
                fill="none"
                class="scribble-path"></path></svg
            >
          </span>
          is
          <span class="relative-word">
            our
            <svg class="word-scribble underline" viewBox="0 0 100 20"
              ><path
                d="M5 15 Q50 18 95 15"
                stroke="#fff"
                stroke-width="3"
                fill="none"
                class="scribble-path"></path></svg
            >
          </span>
          <span class="relative-word">
            mission
            <svg class="word-scribble arrow-down" viewBox="0 0 40 40"
              ><path
                d="M20 5 Q25 20 15 35 M15 35 L5 25 M15 35 L25 28"
                stroke="#fff"
                stroke-width="2.5"
                fill="none"
                class="scribble-path"></path></svg
            >
          </span>
        </h2>
      </div>

      <div class="mission-grid">
        <!-- Left Content -->
        <div class="mission-text reveal">
          <h3 class="mission-subheading">You deserve better.</h3>
          <p>
            You deserve better outcomes, insights, and conversations. You
            deserve to work with the best proactive teams that embrace
            complexity, adapt to ambiguity, and flex to your needs with just 24
            hours notice. You should be obsessed over, not struggling to scale
            or sacrificing quality for speed.
          </p>
          <p>
            Whether you're a disruptive startup or an iconic brand, with Hugo
            you get more than outsourcing — you get what you deserve.
          </p>
          <div class="mission-actions">
            <button class="btn btn-outline-white">Take Hugo for a spin</button>
          </div>
        </div>

        <!-- Right Graphic -->
        <div class="mission-graphic-container reveal">
          <div class="mission-card-outer">
            <!-- Background decoration -->
            <div class="pattern-strip"></div>

            <div class="mission-card-inner">
              <svg viewBox="0 0 500 500" class="process-svg">
                <!-- Background Shape -->
                <path
                  d="M-50 450 Q50 350 250 400 T550 450"
                  fill="#A1E5E7"
                  opacity="0.4"
                  class="bg-splash"></path>

                <!-- Arcs -->
                <path
                  class="process-arc"
                  d="M100 240 A150 150 0 0 1 400 240"
                  stroke="#000"
                  stroke-width="2.5"
                  stroke-dasharray="10 10"
                  fill="none"></path>

                <!-- Big '2' behind -->
                <text
                  x="250"
                  y="320"
                  font-size="140"
                  font-weight="800"
                  text-anchor="middle"
                  fill="#5b62ad"
                  opacity="0.1">2</text
                >

                <!-- Process Circles -->
                <g class="process-node" id="nodeSelect">
                  <circle
                    cx="100"
                    cy="240"
                    r="45"
                    fill="#4DD0E1"
                    stroke="#000"
                    stroke-width="2.5"></circle>
                  <text
                    x="100"
                    y="238"
                    font-size="11"
                    font-weight="800"
                    text-anchor="middle"
                    fill="#000">SELECT</text
                  >
                  <text
                    x="100"
                    y="250"
                    font-size="11"
                    font-weight="800"
                    text-anchor="middle"
                    fill="#000">TEAM</text
                  >
                </g>

                <g class="process-node" id="nodeLaunch">
                  <circle
                    cx="250"
                    cy="100"
                    r="42"
                    fill="#4DD0E1"
                    stroke="#000"
                    stroke-width="2.5"></circle>
                  <text
                    x="250"
                    y="105"
                    font-size="11"
                    font-weight="800"
                    text-anchor="middle"
                    fill="#000">LAUNCH</text
                  >
                </g>

                <g class="process-node" id="nodeIterate">
                  <circle
                    cx="400"
                    cy="240"
                    r="42"
                    fill="#4DD0E1"
                    stroke="#000"
                    stroke-width="2.5"></circle>
                  <text
                    x="400"
                    y="245"
                    font-size="11"
                    font-weight="800"
                    text-anchor="middle"
                    fill="#000">ITERATE</text
                  >
                </g>

                <text
                  x="250"
                  y="260"
                  font-size="20"
                  font-weight="700"
                  text-anchor="middle"
                  fill="#000"
                  letter-spacing="0.05em">- 2 WEEKS -</text
                >
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div> <!-- End mission-container -->

  <!-- Bottom Curve -->
  <div class="curve-bottom">
    <svg viewBox="0 0 1440 140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 0 C 480 140, 960 140, 1440 0 Z" fill="#5b62ad"></path>
    </svg>
  </div>

  <style>
    .mission-section {
      position: relative;
      background-color: transparent;
      margin: 0; /* Fixed overlapping */
      z-index: 5;
      overflow: visible; /* Allow scribbles to pop out if needed */
    }

    .mission-container {
      background-color: #5b62ad;
      padding: 1.5rem 2rem; /* Tightened for 'Smart Look' */
    }

    .container--wide {
      max-width: 1240px;
      margin: 0 auto;
      padding: 0 4rem;
    }

    .curve-top,
    .curve-bottom {
      width: 100%;
      line-height: 0;
      position: relative;
      z-index: 2;
    }

    .curve-top {
      margin-bottom: -2px;
    }
    .curve-bottom {
      margin-top: -2px;
    }

    .curve-top svg,
    .curve-bottom svg {
      width: 100%;
      height: auto;
    }

    /* Header */
    .mission-header {
      margin-bottom: 3rem; /* Tightened for 'Smart Look' */
      text-align: center;
    }

    .mission-title {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 500;
      line-height: 1.15;
      display: inline-flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.1em 0.3em;
      color: #fff;
      position: relative;
      letter-spacing: -0.02em;
    }

    .relative-word {
      position: relative;
      display: inline-block;
    }

    .word-scribble {
      position: absolute;
      pointer-events: none;
      overflow: visible;
    }

    .word-scribble.underline {
      bottom: -0.2em;
      left: 0;
      width: 100%;
      height: 1em;
    }

    .word-scribble.arrow-up {
      bottom: -1.2em;
      left: 10%;
      width: 0.8em;
      height: 1.2em;
    }

    .word-scribble.arrow-down {
      top: -1.2em;
      right: 0%;
      width: 0.8em;
      height: 1.2em;
    }

    /* Content Grid */
    .mission-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .mission-text {
      max-width: 500px;
    }

    .mission-subheading {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1.25rem;
      letter-spacing: -0.01em;
      color: #fff;
    }

    .mission-text p {
      font-size: 0.95rem;
      line-height: 1.5;
      margin-bottom: 1.25rem;
      color: #fff;
      opacity: 0.95;
    }

    /* Graphic Card */
    .mission-graphic-container {
      position: relative;
    }

    .mission-card-outer {
      position: relative;
      width: 100%;
      max-width: 440px;
      margin: 0 auto;
    }

    .mission-card-inner {
      background: white;
      border-radius: 20px;
      padding: 1rem;
      box-shadow: 0 40px 100px rgba(0, 0, 0, 0.06);
      aspect-ratio: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      z-index: 2;
      overflow: hidden;
    }

    .pattern-strip {
      position: absolute;
      right: -20px;
      top: 10%;
      height: 80%;
      width: 60px;
      background-color: #4dd0e1; /* Viking blue accent */
      border-radius: 20px;
      z-index: 1;
      background-image: radial-gradient(
        circle,
        rgba(255, 255, 255, 0.2) 20%,
        transparent 20%
      );
      background-size: 30px 30px;
      background-position: center;
    }

    .process-svg {
      width: 100%;
      height: 100%;
    }

    @media (max-width: 1024px) {
      .mission-grid {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 3rem;
      }
      .mission-text {
        max-width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .mission-subheading {
        font-size: 1.8rem;
      }
      .container--wide {
        padding: 0 1.5rem;
      }
      .mission-card-outer {
        max-width: 440px;
        margin: 0 auto;
      }
    }
  </style>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initMissionAnimations = () => {
      // Scribble paths animation
      const scribbles = document.querySelectorAll(".scribble-path");
      scribbles.forEach((path) => {
        if (!(path instanceof SVGPathElement)) return;
        const length = path.getTotalLength();
        gsap.set(path, { strokeDasharray: length, strokeDashoffset: length });

        gsap.to(path, {
          strokeDashoffset: 0,
          duration: 1.5,
          ease: "power2.inOut",
          scrollTrigger: {
            trigger: ".mission-section",
            start: "top 40%",
          },
        });
      });

      // Dotted arc 'Umbrella' flow animation
      gsap.to(".process-arc", {
        strokeDashoffset: -20, // Negative for left-to-right flow
        duration: 1,
        repeat: -1,
        ease: "none"
      });

      // Process nodes stagger appearing
      gsap.from(".process-node, .process-arc", {
        scale: 0.8,
        opacity: 0,
        duration: 0.8,
        stagger: 0.2,
        ease: "back.out(1.7)",
        scrollTrigger: {
          trigger: ".mission-section",
          start: "top 35%",
        },
      });

      // Floating UI Elements
      gsap.to([".persona-group", ".data-card"], {
        y: -10,
        duration: 3,
        repeat: -1,
        yoyo: true,
        stagger: 0.2,
        ease: "sine.inOut",
      });
    };

    // Ensure it runs after font/images load
    window.addEventListener("load", initMissionAnimations);
  </script>
</section>
