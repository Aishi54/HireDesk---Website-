<section class="mission-section">
  <!-- Top Curve -->
  <div class="curve-top">
    <svg viewBox="0 0 1440 140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 140 C 480 0, 960 0, 1440 140 Z" fill="#5b62ad"></path>
    </svg>
  </div>

  <div class="mission-container">
    <div class="container--wide">
      <!-- Main Title with Scribbles -->
      <div class="mission-header reveal">
        <div class="header-content-wrap">
          <div class="label-box">
             <span class="label-text">WHO WE ARE</span>
             <svg class="label-scribble" viewBox="0 0 100 20">
                <path d="M5 15 Q50 20 95 15" stroke="#fff" stroke-width="2" fill="none" class="scribble-path"></path>
             </svg>
          </div>
          <h2 class="mission-title">
            A Trusted Extension of <span class="accent-line">Your Team</span>
            <svg class="title-scribble" viewBox="0 0 300 20">
               <path d="M10 12 Q150 18 290 12" stroke="#fff" stroke-opacity="0.3" stroke-width="3" fill="none" class="scribble-path"></path>
            </svg>
          </h2>
        </div>
      </div>

      <div class="mission-grid">
        <!-- Left Content -->
        <div class="mission-text reveal">
          <h3 class="mission-subheading">From Burden to Growth</h3>
          <p>
            Running a business is hard. Over time, you find yourself doing everything—from admin and accounts to chasing invoices. We understand what it feels like to carry everything on your shoulders.
          </p>
          <p>
            That is why we created Hire Desk. We don't just provide a service; we become a trusted extension of your team where communication is clear and the support is reliable. We take care of the tasks that slow you down, so you can focus on growing your business.
          </p>
          <div class="mission-actions">
            <button class="btn btn-outline-white">Explore Our Process</button>
          </div>
        </div>

        <!-- Right Graphic -->
        <div class="mission-graphic-container reveal">
          <div class="mission-card-outer">
            <!-- Background decoration -->
            <div class="pattern-strip"></div>

            <div class="mission-card-inner">
              <svg viewBox="0 0 500 500" class="process-svg">
                <!-- Background Shape -->
                <path
                  d="M-50 450 Q50 350 250 400 T550 450"
                  fill="#A1E5E7"
                  opacity="0.4"
                  class="bg-splash"></path>

                <!-- Arcs -->
                <path
                  class="process-arc"
                  d="M100 240 A150 150 0 0 1 400 240"
                  stroke="#000"
                  stroke-width="2.5"
                  stroke-dasharray="10 10"
                  fill="none"></path>

                <!-- Icon/Decoration -->
                <g class="process-node" id="nodeChallenge">
                  <circle
                    cx="100"
                    cy="240"
                    r="45"
                    fill="#4DD0E1"
                    stroke="#000"
                    stroke-width="2.5"></circle>
                  <text
                    x="100"
                    y="245"
                    font-size="11"
                    font-weight="800"
                    text-anchor="middle"
                    fill="#000">BURDEN</text
                  >
                </g>

                <g class="process-node" id="nodeSolution">
                  <circle
                    cx="250"
                    cy="100"
                    r="42"
                    fill="#5b62ad"
                    stroke="#000"
                    stroke-width="2.5"></circle>
                  <text
                    x="250"
                    y="105"
                    font-size="11"
                    font-weight="800"
                    text-anchor="middle"
                    fill="#fff">SUPPORT</text
                  >
                </g>

                <g class="process-node" id="nodeGrowth">
                  <circle
                    cx="400"
                    cy="240"
                    r="42"
                    fill="#4DD0E1"
                    stroke="#000"
                    stroke-width="2.5"></circle>
                  <text
                    x="400"
                    y="245"
                    font-size="11"
                    font-weight="800"
                    text-anchor="middle"
                    fill="#000">GROWTH</text
                  >
                </g>

                <text
                  x="250"
                  y="260"
                  font-size="20"
                  font-weight="700"
                  text-anchor="middle"
                  fill="#000"
                  letter-spacing="0.05em">YOUR BUSINESS</text
                >
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- End mission-container -->

  <!-- Bottom Curve -->
  <div class="curve-bottom">
    <svg viewBox="0 0 1440 140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 0 C 480 140, 960 140, 1440 0 Z" fill="#5b62ad"></path>
    </svg>
  </div>

  <style>
    .mission-section {
      position: relative;
      background-color: transparent;
      margin: 0; /* Fixed overlapping */
      z-index: 5;
      overflow: visible; /* Allow scribbles to pop out if needed */
    }

    .mission-container {
      background-color: #5b62ad;
      padding: 1.5rem 2rem; /* Tightened for 'Smart Look' */
    }

    .container--wide {
      max-width: 1240px;
      margin: 0 auto;
      padding: 0 4rem;
    }

    .curve-top,
    .curve-bottom {
      width: 100%;
      line-height: 0;
      position: relative;
      z-index: 2;
    }

    .curve-top {
      margin-bottom: -2px;
    }
    .curve-bottom {
      margin-top: -2px;
    }

    .curve-top svg,
    .curve-bottom svg {
      width: 100%;
      height: auto;
    }

    /* Header Style Refresh (Screenshot Style) */
    .mission-header {
      margin-bottom: 3.5rem;
      text-align: center;
      display: flex;
      justify-content: center;
    }

    .header-content-wrap {
      display: inline-flex;
      align-items: center;
      gap: 1.5rem;
      position: relative;
    }

    .label-box {
      position: relative;
      padding-top: 0.5rem;
    }

    .label-text {
      font-size: 0.85rem;
      font-weight: 500;
      color: rgba(255,255,255,0.7);
      text-transform: capitalize;
      letter-spacing: 0.05em;
    }

    .label-scribble {
      position: absolute;
      bottom: -6px;
      left: 0;
      width: 100%;
      height: 12px;
      pointer-events: none;
    }

    .mission-title {
      font-size: clamp(2.2rem, 4.5vw, 3.4rem);
      font-weight: 500;
      line-height: 1.05;
      color: #fff;
      position: relative;
      letter-spacing: -3.0333px; /* Precise 'Smart' tracking */
      margin: 0;
    }

    .title-scribble {
      position: absolute;
      bottom: -15px;
      left: 0;
      width: 100%;
      height: 20px;
      pointer-events: none;
      opacity: 0.25;
    }

    .accent-line {
      position: relative;
      display: inline-block;
    }

    .relative-word {
      position: relative;
      display: inline-block;
    }

    .word-scribble {
      position: absolute;
      pointer-events: none;
      overflow: visible;
    }

    .word-scribble.underline {
      bottom: -0.2em;
      left: 0;
      width: 100%;
      height: 1em;
    }

    .word-scribble.arrow-up {
      bottom: -1.2em;
      left: 10%;
      width: 0.8em;
      height: 1.2em;
    }

    .word-scribble.arrow-down {
      top: -1.2em;
      right: 0%;
      width: 0.8em;
      height: 1.2em;
    }

    /* Content Grid */
    .mission-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .mission-text {
      max-width: 500px;
    }

    .mission-subheading {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1.25rem;
      letter-spacing: -0.01em;
      color: #fff;
    }

    .mission-text p {
      font-size: 0.95rem;
      line-height: 1.5;
      margin-bottom: 1.25rem;
      color: #fff;
      opacity: 0.95;
    }

    /* Graphic Card */
    .mission-graphic-container {
      position: relative;
    }

    .mission-card-outer {
      position: relative;
      width: 100%;
      max-width: 440px;
      margin: 0 auto;
    }

    .mission-card-inner {
      background: white;
      border-radius: 20px;
      padding: 1rem;
      box-shadow: 0 40px 100px rgba(0, 0, 0, 0.06);
      aspect-ratio: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      z-index: 2;
      overflow: hidden;
    }

    .pattern-strip {
      position: absolute;
      right: -20px;
      top: 10%;
      height: 80%;
      width: 60px;
      background-color: #4dd0e1; /* Viking blue accent */
      border-radius: 20px;
      z-index: 1;
      background-image: radial-gradient(
        circle,
        rgba(255, 255, 255, 0.2) 20%,
        transparent 20%
      );
      background-size: 30px 30px;
      background-position: center;
    }

    .process-svg {
      width: 100%;
      height: 100%;
    }

    @media (max-width: 1024px) {
      .mission-grid {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 3rem;
      }
      .mission-text {
        max-width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .mission-subheading {
        font-size: 1.8rem;
      }
      .container--wide {
        padding: 0;
      }
      .mission-header,
      .mission-grid {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }
      .mission-card-outer {
        max-width: 440px;
        margin: 0 auto;
      }
    }
  </style>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initMissionAnimations = () => {
      // Scribble paths animation
      const scribbles = document.querySelectorAll(".scribble-path");
      scribbles.forEach((path) => {
        if (!(path instanceof SVGPathElement)) return;
        const length = path.getTotalLength();
        gsap.set(path, { strokeDasharray: length, strokeDashoffset: length });

        gsap.to(path, {
          strokeDashoffset: 0,
          duration: 1.5,
          ease: "power2.inOut",
          scrollTrigger: {
            trigger: ".mission-section",
            start: "top 40%",
          },
        });
      });

      // Dotted arc 'Umbrella' flow animation
      gsap.to(".process-arc", {
        strokeDashoffset: -20, // Negative for left-to-right flow
        duration: 1,
        repeat: -1,
        ease: "none",
      });

      // Process nodes stagger appearing
      gsap.from(".process-node, .process-arc", {
        scale: 0.8,
        opacity: 0,
        duration: 0.8,
        stagger: 0.2,
        ease: "back.out(1.7)",
        scrollTrigger: {
          trigger: ".mission-section",
          start: "top 35%",
        },
      });

      // Floating UI Elements
      gsap.to([".persona-group", ".data-card"], {
        y: -10,
        duration: 3,
        repeat: -1,
        yoyo: true,
        stagger: 0.2,
        ease: "sine.inOut",
      });
    };

    // Ensure it runs after font/images load
    window.addEventListener("load", initMissionAnimations);
  </script>
</section>
