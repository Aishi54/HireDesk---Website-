---
import Graphic from "./Graphic.astro";
---

<section class="hero overflow-hidden">
  <div class="container hero-wrapper">
    <!-- Graphic on the left for desktop -->
    <div class="hero-graphic">
      <Graphic size={400} />
    </div>

    <!-- Content on the right for desktop -->
    <div class="hero-content">
      <div class="tagline-container">
        <span class="tagline">Outsourcing+</span>
        <svg class="scribble" viewBox="0 0 100 12" preserveAspectRatio="none">
          <path d="M0 8 C 20 2, 50 12, 100 4" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round" />
        </svg>
      </div>

      <h1 class="hero-title reveal">Built to make you better.</h1>

      <p class="hero-description reveal">
        We're not traditional outsourcers. We build world-class teams — from
        customer support to AI data solutions — helping you scale faster and
        smarter.
      </p>

      <div class="hero-actions reveal">
        <button class="btn btn-black">Build your Dream Team</button>
      </div>

      <!-- Featured Testimonial Card (Paula Weeks) -->
      <div class="featured-card reveal">
        <div class="card-inner">
          <div class="card-circle">
            <img src="/assets/sarah-sakara.png" alt="Paula Weeks" />
          </div>
          <div class="card-content">
            <span class="card-label">Paula Weeks, FIFA '26 Hospitality Director</span>
            <p class="card-text">
              "Paula brings over 20 years of building innovative customer programs to soccer's largest events."
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Divider Curve -->
  <div class="curve-bottom">
    <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M0 0 C 480 100, 960 100, 1440 0 L 1440 100 L 0 100 Z"
        fill="#FDFCF6"></path>
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: auto;
    display: flex;
    align-items: center;
    background-color: var(--bg-primary);
    padding: 2.5rem 0 4rem; /* More compact */
    overflow: hidden;
  }

  .hero-wrapper {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-graphic {
    flex: 0 0 420px; /* Precise width control */
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    flex: 1;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    position: relative;
    z-index: 2;
  }

  .tagline-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: -4px;
    margin-bottom: 0.5rem;
    width: fit-content;
  }

  .tagline {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-black);
    line-height: 1;
  }

  .scribble {
    width: 110%;
    height: 10px;
    margin-left: -5%;
    color: #333;
  }

  .hero-title {
    font-size: clamp(1.8rem, 3.5vw, 3.1rem); /* Reduced further for compact look */
    line-height: 1.05;
    margin-bottom: 0.75rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: #000;
  }

  .hero-description {
    font-size: 1rem;
    line-height: 1.5;
    color: #555;
    margin-bottom: 1.5rem;
    max-width: 460px;
  }

  .hero-actions {
    margin-bottom: 1.75rem;
  }

  .featured-card {
    background-color: #AEEEEE;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .card-inner {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .card-circle {
    width: 55px;
    height: 55px;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background: #FF8A80;
    border: 2px solid white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-circle img {
    width: 80%;
    height: 80%;
    object-fit: cover;
    border-radius: 50%;
  }

  .card-label {
    display: block;
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 0.2rem;
    color: #000;
  }

  .card-text {
    font-size: 0.78rem;
    line-height: 1.4;
    color: #333;
  }

  .curve-bottom {
    display: none; /* Hide curve if it takes too much space at 100% */
  }

  @media (max-width: 1024px) {
    .hero {
      padding: 0rem 0 2rem; /* Reduced top padding significantly */
    }
    .hero-wrapper {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem; /* Tighter gap */
    }
    .hero-graphic {
      flex: 0 0 auto;
      width: 100%;
      transform: scale(0.9);
    }
    .hero-content {
      align-items: center;
      text-align: center;
      max-width: 100%;
    }
    .tagline-container {
      align-items: center;
    }
    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>
