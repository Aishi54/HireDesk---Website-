---
import Graphic from './Graphic.astro';
---

<section class="hero overflow-hidden">
  <div class="container hero-wrapper">
    <!-- Graphic on the left for desktop -->
    <div class="hero-graphic order-2 lg:order-1">
      <Graphic />
    </div>

    <!-- Content on the right for desktop -->
    <div class="hero-content order-1 lg:order-2">
      <div class="tagline-container">
        <span class="tagline">Outsourcing+</span>
        <div class="tagline-underline"></div>
      </div>
      
      <h1 class="hero-title reveal">Built to make you better.</h1>
      
      <p class="hero-description reveal">
        We're not traditional outsourcers. We build world-class teams — from customer support to AI data solutions — helping you scale faster and smarter.
      </p>
      
      <div class="hero-actions reveal">
        <button class="btn btn-black">Build your Dream Team</button>
      </div>

      <!-- Featured Article Card -->
      <div class="featured-card reveal">
        <div class="card-inner">
          <div class="card-visual">
            <div class="card-circle">
              <img src="/assets/sarah-sakara.png" alt="Featured" />
            </div>
          </div>
          <div class="card-content">
            <span class="card-label">30 Days with book of the month</span>
            <p class="card-text">
              Book of the Month Club (BOTM) promised something different: full access to their back catalog of books.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 100px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    background-color: var(--bg-primary);
    padding: 3rem 0 1rem;
    position: relative;
    overflow: hidden;
  }

  .hero-wrapper {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr; /* Slightly favor graphic */
    align-items: center;
    gap: 2rem;
    width: 100%;
    margin-top: -20px; /* Pull up balance */
  }

  @media (max-width: 1024px) {
    .hero-wrapper {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 4rem;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: 2rem;
  }

  @media (max-width: 1024px) {
    .hero-content {
      align-items: center;
      padding-left: 0;
      order: 1;
    }
    .hero-graphic {
      order: 2;
    }
  }

  /* Tagline Styling */
  .tagline-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    margin-bottom: 1.25rem;
  }

  .tagline {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-black);
  }

  .tagline-underline {
    height: 2px;
    background: var(--color-black);
    width: 40px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1s cubic-bezier(0.19, 1, 0.22, 1) 0.5s;
  }

  .reveal.tagline-container[style*="opacity: 1"] .tagline-underline {
    transform: scaleX(1);
  }

  /* Typography */
  .hero-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    margin-bottom: 0.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #000;
  }

  .hero-description {
    font-size: 0.9rem;
    line-height: 1.35;
    color: #333;
    margin-bottom: 1.25rem;
    max-width: 360px;
  }

  .hero-actions {
    margin-bottom: 1.25rem;
  }

  .btn-black {
    padding: 0.5rem 1.1rem;
    font-size: 0.85rem;
  }

  /* Featured Card */
  .featured-card {
    background-color: #E0F7FA;
    border-radius: 10px;
    padding: 0.75rem;
    width: 100%;
    max-width: 340px;
    position: relative;
    overflow: hidden;
    scale: 0.95;
    transform-origin: left top;
    box-shadow: 0 8px 20px rgba(0,0,0,0.03);
  }

  .card-inner {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .card-circle {
    width: 70px;
    height: 70px;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background: white;
    border: 2px solid white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.08);
  }

  .card-label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .card-text {
    font-size: 0.85rem;
    line-height: 1.4;
    color: #333;
  }

  .card-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: rgba(0,0,0,0.04);
  }

  .progress-bar {
    width: 35%;
    height: 100%;
    background: var(--color-black);
  }

  .hero-graphic {
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 1;
    margin-top: -3.5rem; /* Pull up to align with heading */
  }

  /* Responsive Adjustments */
  @media (max-width: 1024px) {
    .featured-card {
      margin: 0 auto;
      max-width: 100%;
    }
    
    .hero-graphic {
      margin-top: -2rem;
      transform: scale(0.8);
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.2rem;
    }
    
    .card-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
    }
    
    .card-circle {
      margin: 0 auto;
    }
  }
</style>

