---
interface Stat {
  number: string;
  label: string;
}

interface Props {
  stats: Stat[];
  title: string;
  description: string;
}

const { stats, title, description } = Astro.props;
---

<section class="service-stats">
  <div class="container--wide">
    <!-- Stats Grid -->
    <div class="stats-grid">
      {stats.map(stat => (
        <div class="stat-item reveal">
          <h2 class="stat-number">{stat.number}</h2>
          <p class="stat-label">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Hand-drawn Bracket SVG (Exact Path Replication) -->
    <div class="bracket-wrap reveal">
      <svg width="100%" height="100" viewBox="0 0 1200 100" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <!-- The Left half bracket -->
        <path d="M120 20Q120 70 300 70L580 70Q600 70 600 90" stroke="black" stroke-width="2.5" stroke-linecap="round" />
        <!-- The Right half bracket -->
        <path d="M1080 20Q1080 70 900 70L620 70Q600 70 600 90" stroke="black" stroke-width="2.5" stroke-linecap="round" />
        
        <!-- Ticks for inner stats -->
        <path d="M400 70Q400 30 400 25" stroke="black" stroke-width="2" stroke-linecap="round" opacity="0.6" />
        <path d="M800 70Q800 30 800 25" stroke="black" stroke-width="2" stroke-linecap="round" opacity="0.6" />
      </svg>
    </div>

    <!-- Bottom Content -->
    <div class="stats-footer">
      <h2 class="footer-title reveal">{title}</h2>
      <p class="footer-desc reveal">{description}</p>
      
      <div class="cta-wrap reveal">
        <a href="/contact" class="btn btn-black-pill">Connect with us</a>
      </div>
    </div>
  </div>
</section>

<style>
  .service-stats {
    background-color: #FDFCF6;
    padding: 60px 0 80px; /* Compact */
    text-align: center;
    position: relative;
    z-index: 5;
  }

  .container--wide {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-bottom: 1.25rem;
    align-items: end;
  }

  .stat-number {
    font-size: clamp(2rem, 4.2vw, 3rem); /* Scaled down for 'smart' look */
    font-weight: 500;
    color: #000;
    margin-bottom: 0.6rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem; /* Denser, smarter profile */
    color: #555;
    font-weight: 500;
    opacity: 0.8;
    text-transform: capitalize;
  }

  .bracket-wrap {
    max-width: 1000px;
    margin: 0 auto 2.5rem;
    opacity: 0.08; /* Subdued, artistic presence */
    padding: 0 4rem;
  }

  .stats-footer {
    max-width: 800px;
    margin: 0 auto;
  }

  .footer-title {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem); /* Matching page scale */
    font-weight: 500;
    color: #000;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .footer-desc {
    font-size: 0.95rem; /* Denser, smarter profile */
    color: #444;
    margin-bottom: 2.5rem;
    font-weight: 400;
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }

  @media (max-width: 991px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 3rem; margin-bottom: 3rem; }
    .bracket-wrap { display: none; }
  }

  /* Reveal logic */
  .reveal { opacity: 0; transform: translateY(30px); }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initStatsAnimations = () => {
    gsap.to('.service-stats .reveal', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.12,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '.service-stats',
        start: 'top 80%'
      }
    });

    gsap.to('.bracket-wrap path', {
       opacity: 0.2, // Subtle presence
       duration: 2,
       delay: 0.5,
       stagger: 0.2,
       ease: "power2.inOut",
       scrollTrigger: { trigger: '.service-stats', start: 'top 80%' }
    });
  };

  window.addEventListener('load', initStatsAnimations);
</script>
