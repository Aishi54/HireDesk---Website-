<section class="surge-protect">
  <!-- Minimal Top Wave -->
  <div class="wave-top">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none">
      <path d="M0,40 Q720,0 1440,40 L1440,0 L0,0 Z" fill="#FDFCF6"></path>
    </svg>
  </div>

  <div class="container--smart">
    <!-- Header Area - Centered & Refined -->
    <div class="surge-brand reveal">
      <div class="brand-logo">
        <svg width="45" height="52" viewBox="0 0 50 60">
           <path d="M5 10 Q25 5 45 10 L45 35 Q45 50 25 55 Q5 50 5 35 Z" fill="none" stroke="white" stroke-width="3.5"/>
           <path d="M22 15 L32 25 L18 35 L28 45" stroke="white" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="brand-text">
        <h2>SurgeProtect</h2>
        <p>Scale Without Limits</p>
      </div>
    </div>

    <!-- Layout Grid -->
    <div class="surge-main-grid">
      <!-- Left: Compact Description -->
      <div class="surge-left reveal">
        <p class="desc-text">
          From expected surges and urgent projects to unexpected demands, we've got your back. Access elite talent instantly, scale down seamlessly.
        </p>
        <div class="cta-wrapper">
          <a href="#" class="btn-outline-white">Speak to an expert</a>
        </div>
      </div>

      <!-- Right: Minimal Info Card -->
      <div class="surge-right reveal">
        <div class="info-card">
          <div class="info-col">
            <ul>
              <li>Holiday Seasons</li>
              <li>Seasons of the year</li>
              <li>Tax Season</li>
              <li>Crisis Management</li>
            </ul>
          </div>
          <div class="info-col">
            <ul>
              <li>Sporting Events</li>
              <li>Brand Campaigns</li>
              <li>Back to School</li>
              <li>Weather Events and more!</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Minimal Bottom Wave -->
  <div class="wave-bottom">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none">
      <path d="M0,0 Q720,40 1440,0 L1440,40 L0,40 Z" fill="#FDFCF6"></path>
    </svg>
  </div>
</section>

<style>
  .surge-protect {
    background: linear-gradient(135deg, #54c6d7 0%, #5b62ad 60%, #6484c2 100%);
    padding: 3.5rem 0; 
    position: relative;
    color: #fff;
  }

  /* Wave Dividers - Perfectly Subtle */
  .wave-top, .wave-bottom {
    position: absolute;
    width: 100%;
    height: 40px;
    left: 0;
    z-index: 2;
  }
  .wave-top { top: -1px; }
  .wave-bottom { bottom: -1px; }

  .container--smart {
    max-width: 1100px; /* SAME AS OPERATIONAL STEPS FOR CONSISTENCY */
    margin: 0 auto;
    padding: 0 4rem;
    position: relative;
    z-index: 5;
  }

  /* Header Branding - Centered & Smaller */
  .surge-brand {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem; /* REDUCED FROM 4rem */
    text-align: left;
  }

  .brand-logo { transition: transform 0.4s ease; cursor: default; }
  .brand-logo:hover { transform: scale(1.1); }

  h2 {
    font-size: clamp(2rem, 4vw, 2.4rem); /* SHRUNK FROM 3.2rem */
    font-weight: 700;
    margin: 0;
    line-height: 0.9;
    letter-spacing: -0.015em;
  }

  .brand-text p {
    font-size: clamp(1rem, 2vw, 1.25rem); /* SHRUNK FROM 1.8rem */
    font-weight: 500;
    margin: 0;
    margin-top: 0.3rem;
    color: #fff;
    opacity: 0.9;
  }

  /* Main Grid Alignment */
  .surge-main-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .surge-main-grid { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
    .surge-brand { flex-direction: column; text-align: center; }
    .surge-brand h2 { font-size: 2.5rem; }
    .container--smart { padding: 0; }
    .surge-brand, .surge-main-grid { padding-left: 1.5rem; padding-right: 1.5rem; }
  }

  .desc-text {
    font-size: 1.05rem; /* SHRUNK FOR SMART LOOK */
    line-height: 1.45;
    font-weight: 500;
    margin-bottom: 1.5rem;
    max-width: 380px;
    color: #fff;
    opacity: 1;
  }

  @media (max-width: 900px) {
    .desc-text { margin: 0 auto 2.22rem; }
  }

  .btn-smart-black {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 0.8rem 2.2rem;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  /* Info Card - Minimalist */
  .info-card {
    background: #fff;
    border-radius: 14px;
    padding: 1.5rem 1.8rem; /* REDUCED to make it smart */
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    box-shadow: 0 15px 40px rgba(0,0,0,0.06);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .info-card:hover { transform: translateY(-5px); }

  @media (max-width: 600px) {
    .info-card { grid-template-columns: 1fr; padding: 2rem; }
  }

  .info-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .info-col ul li {
    font-size: 1.05rem; /* COMPACT FONT */
    font-weight: 600;
    position: relative;
    padding-left: 1.5rem;
    display: flex;
    align-items: center;
    color: #000;
  }

  .info-col ul li::before {
    content: '';
    position: absolute;
    left: 0;
    width: 6px;
    height: 6px;
    background: #000; /* Legible on white card */
    border-radius: 50%;
  }

  /* Reveal logic */
  .reveal { opacity: 0; transform: translateY(18px); }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initSurgeProtect = () => {
    gsap.to('.surge-protect .reveal', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      scrollTrigger: {
        trigger: '.surge-protect',
        start: 'top 80%'
      }
    });

    // Gentle float for the card
    gsap.to('.info-card', {
      y: -8,
      duration: 3,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
  };

  window.addEventListener('load', initSurgeProtect);
</script>
