---
import Layout from "../../layouts/Layout.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import WhatYouGet from "../../components/WhatYouGet.astro";
import ServiceFeatures from "../../components/ServiceFeatures.astro";
import ServicesStats from '../../components/ServicesStats.astro';
import OperationalSteps from '../../components/OperationalSteps.astro';
import ServicePricing from '../../components/ServicePricing.astro';
import WhyChoose from '../../components/WhyChoose.astro';
import CustomerStories from '../../components/CustomerStories.astro';
import LogoCloud from "../../components/LogoCloud.astro";
---

<Layout
  title="Executive Support | Hire Desk - Reclaim Your Time"
>
  <ServiceHero
    title="Executive Support"
    description="Never miss a beat. We act as a trusted extension of your leadership team, managing the administrative details that move your business forward."
    bgColor="#F0FFF4"
  >
    <LogoCloud
      slot="bottom"
      background="transparent"
      padding="0 0 3rem"
      hideTitle={true}
    />
  </ServiceHero>

  <WhatYouGet
    title="Executive Support"
    description="We take the friction out of executive administration. Our high-performing support teams scale with you, getting to know your business inside and out."
  />

  <ServiceFeatures
    cards={[
      {
        icon: "report",
        title: "Logistics",
        features: [
          "Diary & calendar management",
          "Travel coordination",
          "Expense management",
        ],
      },
      {
        icon: "report",
        title: "Administration",
        features: ["General admin support", "Inbox management", "Document preparation"],
      },
      {
        icon: "support",
        title: "Coordination",
        features: ["Meeting scheduling", "Gatekeeping", "Appointment setting"],
      },
    ]}
  />

  <ServicesStats
    stats={[
      { number: '15h+', label: 'Time saved per week' },
      { number: '100%', label: 'Confidentiality' },
      { number: '24/7', label: 'Availability' },
      { number: '1:1', label: 'Dedicated Support' }
    ]}
    title="Premium Partnership"
    description="High-level support that anticipates your needs and keeps you organized."
  />

  <WhyChoose />

  <CustomerStories />

  <OperationalSteps />

  <ServicePricing 
    price="$18"
    unit="per hour"
  />
</Layout>
