---
import Layout from "../../layouts/Layout.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import WhatYouGet from "../../components/WhatYouGet.astro";
import ServiceFeatures from "../../components/ServiceFeatures.astro";
import ServicesStats from '../../components/ServicesStats.astro';
import OperationalSteps from '../../components/OperationalSteps.astro';
import ServicePricing from '../../components/ServicePricing.astro';
import WhyChoose from '../../components/WhyChoose.astro';
import CustomerStories from '../../components/CustomerStories.astro';
import LogoCloud from "../../components/LogoCloud.astro";
---

<Layout
  title="Additional Support | Hire Desk - Specialized Business Functions"
>
  <ServiceHero
    title="Additional Support"
    description="We provide the specialized support you need, exactly when you need it. Our teams get to know your business inside and out to support your rapid growth."
    bgColor="#FFF9F0"
  >
    <LogoCloud
      slot="bottom"
      background="transparent"
      padding="0 0 3rem"
      hideTitle={true}
    />
  </ServiceHero>

  <WhatYouGet
    title="Additional Support"
    description="Take the friction out of specialized business functions. We act as a high-performing extension of your team, scaling with you at any stage of your journey."
  />

  <ServiceFeatures
    cards={[
      {
        icon: "report",
        title: "Growth & Marketing",
        features: [
          "Marketing assistance",
          "Content scheduling",
          "Social media support",
        ],
      },
      {
        icon: "report",
        title: "Client Care",
        features: ["Customer support", "Helpdesk management", "Inquiry handling"],
      },
      {
        icon: "support",
        title: "Technical Support",
        features: ["Basic IT support", "Software setup", "Tool integration"],
      },
    ]}
  />

  <ServicesStats
    stats={[
      { number: '24/7', label: 'Support Readiness' },
      { number: '100%', label: 'Flexible Scaling' },
      { number: '90%', label: 'Setup Speed' },
      { number: '24/7', label: 'Domain Expertise' }
    ]}
    title="Expert Assistance"
    description="Bridge the skills gap in your business with high-performing specialist support."
  />

  <WhyChoose />

  <CustomerStories />

  <OperationalSteps />

  <ServicePricing 
    price="$14"
    unit="per hour"
  />
</Layout>
