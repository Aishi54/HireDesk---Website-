---
import Layout from "../../layouts/Layout.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import WhatYouGet from "../../components/WhatYouGet.astro";
import ServiceFeatures from "../../components/ServiceFeatures.astro";
import ServicesStats from '../../components/ServicesStats.astro';
import OperationalSteps from '../../components/OperationalSteps.astro';
import ServicePricing from '../../components/ServicePricing.astro';
import WhyChoose from '../../components/WhyChoose.astro';
import CustomerStories from '../../components/CustomerStories.astro';
import LogoCloud from "../../components/LogoCloud.astro";
---

<Layout
  title="Financial Support | Hire Desk - Expert Financial Administration"
>
  <ServiceHero
    title="Financial Support"
    description="Dedicated financial assistance to keep your accounts in order and your business compliant. From bookkeeping to VAT preparation, we handle the numbers so you can focus on growth."
    bgColor="#F0F9FF"
  >
    <LogoCloud
      slot="bottom"
      background="transparent"
      padding="0 0 3rem"
      hideTitle={true}
    />
  </ServiceHero>

  <WhatYouGet
    title="Financial Support"
    description="Hire Desk acts as a trusted extension of your finance team, taking ownership of the day-to-day accounting tasks that require precision and consistency."
  />

  <ServiceFeatures
    cards={[
      {
        icon: "report",
        title: "Accounting Basics",
        features: [
          "Bookkeeping",
          "Bank reconciliation",
          "Journal entries",
        ],
      },
      {
        icon: "report",
        title: "Tax & Compliance",
        features: ["VAT preparation", "Filing support", "Expense tracking"],
      },
      {
        icon: "support",
        title: "Payments",
        features: ["Accounts payable", "Accounts receivable", "Invoice generation"],
      },
    ]}
  />

  <ServicesStats
    stats={[
      { number: '100%', label: 'Accuracy in Reporting' },
      { number: '20+', label: 'Years Commercial Exp' },
      { number: '98%', label: 'Retention Rate' },
      { number: '24/7', label: 'Support Available' }
    ]}
    title="Reliable Financial Support"
    description="Expert assistance that integrates seamlessly with your existing accounting software and workflows."
  />

  <WhyChoose />

  <CustomerStories />

  <OperationalSteps />

  <ServicePricing />
</Layout>
