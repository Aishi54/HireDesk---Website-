---
import Layout from "../../layouts/Layout.astro";
import Graphic from "../../components/Graphic.astro";
import FloatingGraphicRight from "../../components/FloatingGraphicRight.astro";
---

<Layout title="Hiring Alternative | Hire Desk Case Study">
  <article class="case-study-page">
    <div class="case-study-hero" style="--accent: #6484c2;">
      <div class="container--hero">
        <div class="hero-content reveal">
          <span class="category">Hiring Strategy</span>
          <h1 class="hero-title">
            A flexible <span class="accent-text">alternative</span> to building an in-house team
          </h1>
          <p class="hero-subtitle">Support Without the Cost of Hiring</p>
          <a href="/get-started" class="btn btn-black-pill">Build Your Dream Team</a>
        </div>
        <div class="hero-visual reveal">
          <div class="img-wrap">
            <img
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=900&auto=format&fit=crop"
              alt="Flexible hiring and remote team"
            />
            <div class="img-badge">Hiring Strategy</div>
          </div>
        </div>
      </div>
    </div>

    <div class="case-study-content">
      <div class="side-visual-right">
        <FloatingGraphicRight />
      </div>

      <div class="container--narrow">
        <div class="content-section reveal">
          <div class="label-box">
            <span class="label-text">The Client</span>
            <svg class="label-scribble" viewBox="0 0 100 20"
              ><path
                d="M5 15 Q50 20 95 15"
                stroke="#6484c2"
                stroke-width="2"
                fill="none"></path></svg
            >
          </div>
          <p class="meta-info">SME reviewing hiring strategy</p>
        </div>

        <div class="content-section reveal">
          <h2>The Challenge</h2>
          <div class="text-block">
            <p>
              The business needed additional support across admin and finance
              but faced high costs associated with hiring locally. Recruitment,
              salaries, National Insurance, pensions and HR obligations made
              hiring a significant long-term commitment.
            </p>
            <p>
              The business needed a more flexible solution without compromising
              on quality.
            </p>
          </div>
        </div>

        <div class="reality-box reveal">
          <h3>Our Approach</h3>
          <p>
            Hire Desk provided a tailored support model that replaced the need
            for multiple local hires. Support included:
          </p>
          <ul class="check-list">
            <li>Bookkeeping and accounts administration</li>
            <li>Back-office and operational support</li>
            <li>Ongoing day-to-day business support</li>
          </ul>
          <p style="margin-top: 1.5rem; font-size: 0.95rem; opacity: 0.8;">
            Delivered through a consistent and structured model aligned to the
            business needs.
          </p>
        </div>

        <div class="outcome-box reveal">
          <h2>The Outcome</h2>
          <div class="text-block">
            <p>
              The business gained access to reliable support without the
              complexity and cost of local hiring. They were able to operate
              more efficiently with a clear and predictable cost structure.
            </p>
          </div>

          <div class="results-grid">
            <div class="result-item">
              <span class="val">Cost Saving</span>
              <p>Reduced overall cost compared to local hiring</p>
            </div>
            <div class="result-item">
              <span class="val">Zero Risk</span>
              <p>No HR or employment-related overheads</p>
            </div>
            <div class="result-item">
              <span class="val">Flexibility</span>
              <p>Support that could scale with the business</p>
            </div>
          </div>
        </div>

        <div class="page-footer-nav reveal">
          <a href="/get-started" class="btn btn-black"
            >Build Your Flexible Team</a
          >
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .case-study-page {
    background: #fff;
  }
  .case-study-hero {
    background-color: #fdfcf6;
    padding: 2rem 0 3rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    position: relative;
    overflow: hidden;
  }

  .container--hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 4rem;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 3rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .img-wrap {
    position: relative;
    width: 100%;
    max-width: 420px;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,0.12);
    aspect-ratio: 4/3;
  }

  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }

  .img-wrap:hover img {
    transform: scale(1.05);
  }

  .img-badge {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background: rgba(0,0,0,0.75);
    color: #fff;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    backdrop-filter: blur(6px);
  }

  .accent-text { color: #6484c2; }

  .absolute-graphic {
    display: none;
  }
  .side-visual-right {
    display: none;
  }

  .container--narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .category {
    display: inline-block;
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 700;
    line-height: 1.15;
    color: #000;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1rem;
    color: #555;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 1024px) {
    .container--hero {
      grid-template-columns: 1fr;
      padding: 0 1.5rem;
      gap: 2rem;
    }
    .hero-image-wrap {
      display: none;
    }
    .hero-content {
      align-items: center;
      text-align: center;
    }
  }

  .case-study-content {
    padding: 80px 0 120px;
    background-color: #fff;
    position: relative;
    overflow: hidden;
  }

  .content-section {
    margin-bottom: 5rem;
  }

  .label-box {
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    width: fit-content;
  }

  .label-text {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
  }

  .label-scribble {
    width: 100%;
    height: 12px;
    margin-top: -4px;
    opacity: 0.4;
  }

  .meta-info {
    font-size: 1.2rem;
    font-weight: 700;
    color: #000;
  }

  h2 {
    font-size: 2.2rem;
    font-weight: 700;
    color: #000;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .text-block p {
    font-size: 1.15rem;
    line-height: 1.6;
    color: #333;
    margin-bottom: 1.5rem;
  }

  .reality-box {
    background-color: rgba(100, 132, 194, 0.05);
    padding: 3rem;
    border-radius: 32px;
    margin-bottom: 4rem;
    border: 1px solid rgba(100, 132, 194, 0.1);
  }

  .reality-box h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .check-list li {
    position: relative;
    padding-left: 2.5rem;
    font-weight: 600;
    font-size: 1.05rem;
    color: #000;
  }

  .check-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: -2px;
    width: 24px;
    height: 24px;
    background: #6484c2;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .result-item {
    background: #f8f9fa;
    padding: 2rem;
    border-radius: 20px;
    text-align: center;
    border: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .result-item:hover {
    background: #fff;
    border-color: #6484c2;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .result-item .val {
    display: block;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #6484c2;
    margin-bottom: 0.5rem;
  }

  .result-item p {
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.3;
    margin: 0;
  }

  .page-footer-nav {
    margin-top: 6rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .results-grid {
      grid-template-columns: 1fr;
    }
    .reality-box {
      padding: 2rem;
    }
    .side-visual-right {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const initHero = () => {
    gsap.to('.hero-content', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
    gsap.to('.hero-visual',  { opacity: 1, y: 0, duration: 1.1, delay: 0.15, ease: 'power3.out' });

    const paths = document.querySelectorAll<SVGPathElement>('.flow-path');
    paths.forEach((path, i) => {
      const length = path.getTotalLength();
      gsap.set(path, { strokeDasharray: length, strokeDashoffset: length });
      gsap.to(path, { strokeDashoffset: -length, duration: 4 + i, repeat: -1, ease: 'none', delay: i * 0.5 });
    });

    gsap.to('.center-logo', { y: -12, duration: 3, repeat: -1, yoyo: true, ease: 'sine.inOut' });

    gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
      gsap.fromTo(el,
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 1, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%', once: true } }
      );
    });
  };

  window.addEventListener('load', initHero);
</script>
