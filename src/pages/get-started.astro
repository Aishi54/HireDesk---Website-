---
import Layout from '../layouts/Layout.astro';
import GetStartedForm from '../components/GetStartedForm.astro';
---

<Layout title="Get Started | Hiredesk - Build Your Dream Team" hideNav={true} hideFooter={true}>
  <main class="get-started-page">
    <div class="page-header">
       <div class="header-inner">
          <a href="/" class="small-logo">
            <img src="/assets/hiredesk-logo.png" alt="Hiredesk" width="180" height="auto" />
          </a>
          <a href="/" class="close-btn" aria-label="Close">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
               <line x1="18" y1="6" x2="6" y2="18"></line>
               <line x1="6" y1="6" x2="18" y2="18"></line>
             </svg>
          </a>
       </div>
    </div>
    
    <div class="form-container">
       <GetStartedForm />
    </div>
  </main>
</Layout>

<style>
  .get-started-page {
    background-color: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .page-header {
    padding: 0 4rem 0; 
  }

  .small-logo img {
    width: 180px;
    height: auto;
    display: block;
    transition: width 0.3s ease;
  }


  .header-inner {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .close-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    color: #fff;
    border-radius: 50%;
    transition: transform 0.3s ease;
  }

  .close-btn:hover {
    transform: rotate(90deg) scale(1.1);
  }

  .form-container {
    flex: 1;
    display: flex;
    align-items: flex-start; 
    justify-content: center;
    padding: 0rem 2rem 4rem; 
    margin-top: -100px; /* Ultra-aggressive top docking */
  }

  @media (max-width: 768px) {
    .page-header { padding: 1.5rem 1.5rem 0.5rem; }
    .small-logo img { width: 140px; }
    .form-container { 
      margin-top: 0 !important; 
      padding-top: 2.5rem !important; 
    }
  }
</style>
