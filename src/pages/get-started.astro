---
import Layout from "../layouts/Layout.astro";
import GetStartedForm from "../components/GetStartedForm.astro";
---

<Layout title="Get Started | Hire Desk - Build Your Dream Team" hideNav={true} hideFooter={true}>
  <main class="get-started-page">
    <header class="page-header">
      <div class="header-inner">
        <a href="/" class="small-logo" aria-label="Hire Desk">
          <img
            src="/assets/hiredesk-logo.png"
            alt="Hire Desk"
            width="140"
            height="auto"
          />
        </a>
        <a href="/" class="close-btn" aria-label="Close">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </a>
      </div>
    </header>

    <div class="form-container">
      <GetStartedForm />
    </div>
  </main>
</Layout>

<style>
  .get-started-page {
    background-color: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    position: relative;
    padding-top: 0; /* Removed top padding */
  }

  .page-header {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    padding: 0.5rem 4rem; /* Bare minimum vertical padding */
    z-index: 100;
  }

  .header-inner {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .small-logo img {
    width: 140px;
    height: auto;
    display: block;
  }

  .close-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    color: #fff;
    border-radius: 50%;
    transition: all 0.3s ease;
  }

  .close-btn:hover {
    transform: rotate(90deg) scale(1.1);
  }

  .form-container {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 6rem 1.5rem 4rem; /* Balanced gap from top navigation */
  }
</style>
